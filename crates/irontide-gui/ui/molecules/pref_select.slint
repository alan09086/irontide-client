// Preferences dropdown select (M184, updated v0.187.1).
//
// The trigger button lives inline; the popup menu is rendered by the
// shared popup service on PreferencesDialog (outside the clip:true
// content Flickable). PrefSelect emits `request-popup` with its
// absolute position; the host renders one overlay for all dropdowns.

import { Tokens } from "../tokens.slint";

export component PrefSelect inherits Rectangle {
    in-out property <string> current-value: "";
    in property <[string]> options: [];
    in property <bool> select-enabled: true;
    in property <string> select-id: "";
    callback value-changed(string);
    callback request-popup(/* id */ string, /* abs-x */ length, /* abs-y */ length, /* width */ length);

    // Set by the shared popup host when this dropdown's popup is open.
    in property <bool> popup-open: false;

    height: Tokens.chrome-h - Tokens.sp-2;
    horizontal-stretch: 1;
    background: select-touch.has-hover && root.select-enabled
        ? Tokens.bg-hover : Tokens.bg-inset;
    border-color: root.popup-open ? Tokens.accent : Tokens.border-1;
    border-width: Tokens.border-width-thin;
    border-radius: Tokens.r-md;
    opacity: root.select-enabled ? 1.0 : 0.5;

    HorizontalLayout {
        padding-left: Tokens.sp-4;
        padding-right: Tokens.sp-4;
        alignment: space-between;

        Text {
            text: root.current-value;
            color: root.select-enabled ? Tokens.fg-0 : Tokens.fg-3;
            font-size: Tokens.fs-13;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        Text {
            text: root.popup-open ? "▲" : "▼";
            color: Tokens.fg-2;
            font-size: 10px;
            vertical-alignment: center;
        }
    }

    select-touch := TouchArea {
        enabled: root.select-enabled;
        clicked => {
            root.request-popup(root.select-id, self.absolute-position.x, self.absolute-position.y + root.height + Tokens.sp-1, root.width);
        }
    }
}
