// PillRow molecule (M177) — extracted from `tweaks.slint`.
//
// A small row of pill-shaped option buttons with a label on the left.
// First introduced for the Tweaks overlay (M172b) and now reused by the
// DetailPane organism for its General/Content tab switcher.
//
// Visual properties flow through the M172b `Tokens` global. No literal
// colours / sizes here.

import { Tokens } from "../tokens.slint";

export component PillRow {
    in property <string> label;
    in property <[string]> options;
    in property <string> selected;
    in property <bool> disabled: false;
    callback option-clicked(string);

    HorizontalLayout {
        spacing: Tokens.sp-4;
        alignment: start;

        Text {
            text: root.label;
            color: Tokens.fg-2;
            font-size: Tokens.fs-13;
            width: Tokens.sp-10 * 2;
            vertical-alignment: center;
        }

        for opt[idx] in root.options: Rectangle {
            background: root.selected == opt ? Tokens.accent : Tokens.bg-2;
            border-radius: Tokens.r-md;
            border-width: Tokens.border-width-thin;
            border-color: Tokens.border-1;
            // M178 fix: previously the Text inside used absolute `x`/`y`
            // positioning, which left the Rectangle's preferred-width
            // unable to grow with the text. With a HorizontalLayout +
            // padding the Rectangle hugs the text, so 5-tab DetailPane
            // labels and Tweaks pill labels both render in full.
            height: Tokens.row-h;

            HorizontalLayout {
                padding-left: Tokens.sp-4;
                padding-right: Tokens.sp-4;
                alignment: center;

                Text {
                    text: opt;
                    color: root.selected == opt
                        ? Tokens.accent-fg
                        : (root.disabled ? Tokens.fg-3 : Tokens.fg-1);
                    font-size: Tokens.fs-12;
                    vertical-alignment: center;
                }
            }

            touch := TouchArea {
                enabled: !root.disabled;
                clicked => { root.option-clicked(opt); }
            }
        }
    }
}
