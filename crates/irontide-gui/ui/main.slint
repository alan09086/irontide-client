// IronTide GUI — dark-theme Slint scaffold (M162) + torrent list (M163)
// Custom widgets only — no std-widgets (hit-region issues on native backends).
// Retrofitted to the Tokens design-system globals in M172b Lane B.

import { Tokens, Shadow } from "tokens.slint";
import { TorrentProgressBar } from "widgets/progress_bar.slint";
import { StatusBar } from "widgets/status_bar.slint";
import { AddMagnetDialog } from "widgets/add_magnet_dialog.slint";
import { AddTorrentDialog } from "widgets/add_torrent_dialog.slint";
import { ContextMenu } from "widgets/context_menu.slint";
import { ConfirmDeleteDialog } from "widgets/confirm_delete_dialog.slint";
import { TweaksOverlay } from "tweaks.slint";
// M173 Lane A: sidebar IA. Layout wiring lands in task A8; A6 imports the
// `SidebarRow` struct here so slint_build picks up the new files and Rust
// callers can see the struct via slint::include_modules!(). The `Sidebar`
// component itself is wired into the MainWindow body in task A8.
import { Sidebar, SidebarRow } from "organisms/sidebar.slint";

export { Tokens, Shadow, SidebarRow }

export struct TorrentRow {
    info-hash: string,
    name: string,
    total-size: string,
    progress: float,
    progress-text: string,
    down-rate: string,
    up-rate: string,
    seeds: string,
    peers: string,
    eta: string,
    state: string,
    state-color: color,
    ratio: string,
    selected: bool,
}

component MenuButton {
    in property <string> text;
    callback clicked();

    min-height: Tokens.sp-9 - Tokens.sp-1;
    min-width: Tokens.sp-10 + Tokens.sp-7;

    Rectangle {
        background: touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
        border-radius: Tokens.r-sm;

        Text {
            text: root.text;
            color: Tokens.fg-0;
            font-size: Tokens.fs-13;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        touch := TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

component MenuBar {
    callback menu-file-action(int);

    height: Tokens.chrome-h;

    Rectangle {
        background: Tokens.bg-1;
        border-width: 0;

        HorizontalLayout {
            padding-left: Tokens.sp-2;
            spacing: Tokens.sp-1;
            alignment: start;

            file-btn := MenuButton {
                text: "File";
                clicked => { file-popup.show(); }
            }
        }
    }

    file-popup := PopupWindow {
        x: Tokens.sp-2;
        y: Tokens.chrome-h;
        width: Tokens.sidebar-w;

        Rectangle {
            background: Tokens.bg-1;
            border-color: Tokens.border-1;
            border-width: Tokens.border-width-thin;
            border-radius: Tokens.r-md;

            VerticalLayout {
                padding: Tokens.sp-2;
                spacing: Tokens.sp-1;

                // Item 0: Add Magnet...
                Rectangle {
                    height: Tokens.row-h;
                    background: magnet-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Add Magnet...";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: Tokens.sp-4;
                    }

                    magnet-touch := TouchArea {
                        clicked => { root.menu-file-action(0); }
                    }
                }

                // Item 1: Add Torrent File...
                Rectangle {
                    height: Tokens.row-h;
                    background: torrent-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Add Torrent File...";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: Tokens.sp-4;
                    }

                    torrent-touch := TouchArea {
                        clicked => { root.menu-file-action(1); }
                    }
                }

                // Separator
                Rectangle {
                    height: Tokens.border-width-thin;
                    background: Tokens.border-1;
                }

                // Item 2: Quit
                Rectangle {
                    height: Tokens.row-h;
                    background: quit-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Quit";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: Tokens.sp-4;
                    }

                    quit-touch := TouchArea {
                        clicked => { root.menu-file-action(2); }
                    }
                }
            }
        }
    }
}

component Spinner {
    width: Tokens.sp-9;
    height: Tokens.sp-9;

    rect := Rectangle {
        width: Tokens.sp-9;
        height: Tokens.sp-9;
        border-radius: Tokens.r-md;
        border-width: Tokens.border-width-thick - Tokens.border-width-thin;
        border-color: Tokens.accent;
        background: transparent;
        clip: true;

        // Animated indicator bar
        indicator := Rectangle {
            x: -Tokens.sp-6;
            y: Tokens.sp-3;
            width: Tokens.sp-7;
            height: Tokens.sp-7;
            border-radius: Tokens.r-lg;
            background: Tokens.fg-0;
            opacity: 0.6;

            animate x {
                duration: 1200ms;
                iteration-count: -1;
                easing: ease-in-out;
            }
        }
    }

    // Drive animation via states
    states [
        spinning when true: {
            indicator.x: Tokens.row-h;
        }
    ]
}

export component MainWindow inherits Window {
    title: "IronTide";
    min-width: Tokens.win-min-width;
    min-height: Tokens.win-min-height;
    preferred-width: Tokens.win-preferred-width;
    preferred-height: Tokens.win-preferred-height;
    background: Tokens.bg-0;

    // ── Skin gate (M172b Lane A + B) ──
    // Set to true by Rust after SkinSettings::apply populates Tokens.
    // Until then, the main chrome is hidden and a minimal spinner shown.
    in-out property <bool> skin-applied: false;

    // ── Session state ──
    in-out property <bool> session-ready: false;
    in-out property <string> status-text: "";
    in-out property <string> error-text: "";
    in-out property <string> toast-text: "";
    in-out property <bool> toast-visible: false;
    in-out property <bool> toast-is-error: false;
    in-out property <string> default-download-dir: "";

    // ── Torrent model ──
    in-out property <[TorrentRow]> torrent-model;

    // ── Sort state ──
    in-out property <int> sort-column: 0;
    in-out property <bool> sort-ascending: true;

    // ── Status bar ──
    in-out property <string> status-down-rate: "\u{2014}";
    in-out property <string> status-up-rate: "\u{2014}";
    in-out property <int> status-total-torrents: 0;
    in-out property <int> status-dht-nodes: 0;
    in-out property <int> status-listen-port: 0;

    // ── Modifier tracking ──
    in-out property <bool> shift-held: false;
    in-out property <bool> ctrl-held: false;
    in-out property <bool> meta-held: false;

    // ── Column widths (set from Rust, used for layout) ──
    // Fixed columns: Progress + State + DownRate + UpRate + Seeds + Peers
    //                + Eta + Size + Ratio; Name gets the remaining space.
    // Defaults come from the `Tokens.col-default-*` fallbacks so no
    // literal px values leak into main.slint — Rust overrides these from
    // the persisted GuiConfig on startup.
    in-out property <length> col-name-width:
        root.width > Tokens.col-width-threshold
            ? root.width - Tokens.col-width-non-name-total
            : Tokens.col-default-name;
    in-out property <length> col-progress-width: Tokens.col-default-progress;
    in-out property <length> col-state-width: Tokens.col-default-state;
    in-out property <length> col-down-rate-width: Tokens.col-default-rate;
    in-out property <length> col-up-rate-width: Tokens.col-default-rate;
    in-out property <length> col-seeds-width: Tokens.col-default-count;
    in-out property <length> col-peers-width: Tokens.col-default-count;
    in-out property <length> col-eta-width: Tokens.col-default-eta;
    in-out property <length> col-size-width: Tokens.col-default-rate;
    in-out property <length> col-ratio-width: Tokens.col-default-ratio;

    // ── Add Magnet Dialog ──
    in-out property <bool> show-add-magnet-dialog: false;
    callback add-magnet-confirmed(string, string);
    callback browse-magnet-download-dir();

    // ── Add Torrent Dialog ──
    in-out property <bool> show-add-torrent-dialog: false;
    in-out property <string> add-torrent-file-path: "";
    in-out property <string> add-torrent-name: "";
    in-out property <string> add-torrent-size: "";
    in-out property <int> add-torrent-file-count: 0;
    callback add-torrent-confirmed(string, string);
    callback browse-torrent-file();
    callback browse-torrent-download-dir();

    // ── Context Menu ──
    in-out property <bool> show-context-menu: false;
    in-out property <length> context-menu-x: 0;
    in-out property <length> context-menu-y: 0;
    in-out property <bool> ctx-can-pause: true;
    in-out property <bool> ctx-can-resume: true;
    in-out property <bool> ctx-can-seed-only: true;
    in-out property <bool> ctx-can-resume-download: true;
    in-out property <bool> ctx-can-recheck: true;
    callback context-action(int);
    callback row-right-clicked(/* info-hash */ string, /* x */ length, /* y */ length);

    // ── Delete Confirmation Dialog ──
    in-out property <bool> show-delete-dialog: false;
    in-out property <int> delete-dialog-count: 0;
    in-out property <bool> delete-dialog-delete-files: false;
    callback delete-confirmed(/* delete_files */ bool);

    // ── Keyboard shortcuts ──
    callback toggle-pause-resume();
    callback delete-selected();
    callback select-all();
    callback show-details-stub();
    // M173 Lane A: Ctrl+1..9 / Cmd+1..9 sidebar shortcuts. The payload
    // is the raw digit text (`"1"`..`"9"`); Rust validates the
    // platform accelerator via `accel::parse_sidebar_shortcut` against
    // `ctrl-held` / `meta-held` and resolves the slot against the
    // visible sidebar order in `AppState`. Fires only when no
    // modal/menu has focus (focus-scope isolation — see the gate in
    // the FocusScope handler below).
    callback sidebar-shortcut(/* digit text "1".."9" */ string);

    // ── Tweaks overlay (M172b Lane B) ──
    in-out property <bool> show-tweaks: false;
    in-out property <string> current-skin: "tide";
    in-out property <string> current-theme: "dark";
    in-out property <string> current-density: "balanced";
    in-out property <string> current-radius: "balanced";
    callback tweaks-skin-changed(string);
    callback tweaks-theme-changed(string);
    callback tweaks-density-changed(string);
    callback tweaks-radius-changed(string);

    public function close-tweaks() {
        root.show-tweaks = false;
    }

    // ── Callbacks ──
    callback menu-file-action(int);
    callback quit-requested();
    callback sort-requested(/* column index */ int);
    callback row-clicked(/* info-hash */ string, /* shift */ bool, /* ctrl */ bool);

    // ── FocusScope for keyboard shortcuts + modifier key tracking ──
    focus-scope := FocusScope {
        key-pressed(event) => {
            // Ctrl+Shift+T (Cmd+Shift+T on macOS): toggle Tweaks overlay.
            // Checked before other shortcuts so it works even while a
            // dialog is open (the overlay closes dialogs first).
            if root.shift-held
               && (root.ctrl-held || root.meta-held)
               && (event.text == "t" || event.text == "T") {
                root.show-tweaks = !root.show-tweaks;
                return accept;
            }
            // Keyboard shortcuts (only when no dialog/menu is open).
            // The Tweaks overlay is treated as modal too — it absorbs
            // its own keys above, so any leftover key event with
            // root.show-tweaks should not trigger sidebar shortcuts.
            if !root.show-add-magnet-dialog && !root.show-add-torrent-dialog && !root.show-delete-dialog && !root.show-context-menu && !root.show-tweaks {
                if event.text == " " {
                    root.toggle-pause-resume();
                    return accept;
                }
                if event.text == Key.Delete {
                    root.delete-selected();
                    return accept;
                }
                if event.text == Key.Return {
                    root.show-details-stub();
                    return accept;
                }
                if event.text == "a" && root.ctrl-held {
                    root.select-all();
                    return accept;
                }
                // M173 Lane A: Ctrl+1..9 (Cmd+1..9 on macOS) — sidebar
                // shortcut. Slint cannot cfg-gate, so we forward the
                // digit text and the modifier flags; Rust's
                // `parse_sidebar_shortcut` then locks the match to the
                // platform accelerator.
                if (root.ctrl-held || root.meta-held)
                   && (event.text == "1" || event.text == "2"
                       || event.text == "3" || event.text == "4"
                       || event.text == "5" || event.text == "6"
                       || event.text == "7" || event.text == "8"
                       || event.text == "9") {
                    root.sidebar-shortcut(event.text);
                    return accept;
                }
            }
            // Escape: dismiss open dialogs/menus (priority order)
            if event.text == Key.Escape {
                if root.show-tweaks {
                    root.show-tweaks = false;
                    return accept;
                }
                if root.show-context-menu {
                    root.show-context-menu = false;
                    return accept;
                }
                if root.show-delete-dialog {
                    root.show-delete-dialog = false;
                    return accept;
                }
                if root.show-add-magnet-dialog {
                    root.show-add-magnet-dialog = false;
                    return accept;
                }
                if root.show-add-torrent-dialog {
                    root.show-add-torrent-dialog = false;
                    return accept;
                }
            }
            // Modifier tracking
            if event.text == Key.Shift {
                root.shift-held = true;
            }
            if event.text == Key.Control {
                root.ctrl-held = true;
            }
            if event.text == Key.Meta {
                root.meta-held = true;
            }
            accept
        }
        key-released(event) => {
            if event.text == Key.Shift {
                root.shift-held = false;
            }
            if event.text == Key.Control {
                root.ctrl-held = false;
            }
            if event.text == Key.Meta {
                root.meta-held = false;
            }
            accept
        }

        VerticalLayout {
            // Menu bar at top
            menu := MenuBar {
                menu-file-action(index) => {
                    root.menu-file-action(index);
                }
            }

            // Main content area
            Rectangle {
                background: Tokens.bg-0;
                vertical-stretch: 1;

                // Loading state: spinner + message
                if !root.session-ready && root.error-text == "": VerticalLayout {
                    alignment: center;

                    HorizontalLayout {
                        alignment: center;
                        Spinner { }
                    }

                    Text {
                        text: "Starting session...";
                        color: Tokens.fg-3;
                        font-size: Tokens.fs-16;
                        horizontal-alignment: center;
                    }
                }

                // Ready state with empty model: empty placeholder
                if root.session-ready && root.error-text == "" && root.torrent-model.length == 0: VerticalLayout {
                    alignment: center;
                    spacing: Tokens.sp-4;

                    Text {
                        text: "No torrents yet.";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-18;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Use File > Add Magnet to get started.";
                        color: Tokens.fg-3;
                        font-size: Tokens.fs-14;
                        horizontal-alignment: center;
                    }
                }

                // Ready state with torrents: table header + list
                if root.session-ready && root.error-text == "" && root.torrent-model.length > 0: VerticalLayout {
                    spacing: 0;

                    // ── Table Header ──
                    Rectangle {
                        height: Tokens.chrome-h - Tokens.sp-5;
                        background: Tokens.bg-2;

                        // Name
                        Rectangle {
                            x: 0;
                            width: root.col-name-width;
                            height: parent.height;

                            hdr-name-touch := TouchArea {
                                clicked => { root.sort-requested(0); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Name" + (root.sort-column == 0 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                x: Tokens.sp-3;
                            }
                        }

                        // Progress
                        Rectangle {
                            x: root.col-name-width;
                            width: root.col-progress-width;
                            height: parent.height;

                            hdr-progress-touch := TouchArea {
                                clicked => { root.sort-requested(1); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Progress" + (root.sort-column == 1 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                x: Tokens.sp-2;
                            }
                        }

                        // State
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width;
                            width: root.col-state-width;
                            height: parent.height;

                            hdr-state-touch := TouchArea {
                                clicked => { root.sort-requested(2); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "State" + (root.sort-column == 2 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                x: Tokens.sp-2;
                            }
                        }

                        // Down Rate
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width;
                            width: root.col-down-rate-width;
                            height: parent.height;

                            hdr-down-rate-touch := TouchArea {
                                clicked => { root.sort-requested(3); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "\u{2193}" + (root.sort-column == 3 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - Tokens.sp-3;
                            }
                        }

                        // Up Rate
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width;
                            width: root.col-up-rate-width;
                            height: parent.height;

                            hdr-up-rate-touch := TouchArea {
                                clicked => { root.sort-requested(4); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "\u{2191}" + (root.sort-column == 4 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - Tokens.sp-3;
                            }
                        }

                        // Seeds
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width;
                            width: root.col-seeds-width;
                            height: parent.height;

                            hdr-seeds-touch := TouchArea {
                                clicked => { root.sort-requested(5); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Seeds" + (root.sort-column == 5 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - Tokens.sp-3;
                            }
                        }

                        // Peers
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width;
                            width: root.col-peers-width;
                            height: parent.height;

                            hdr-peers-touch := TouchArea {
                                clicked => { root.sort-requested(6); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Peers" + (root.sort-column == 6 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - Tokens.sp-3;
                            }
                        }

                        // ETA
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width;
                            width: root.col-eta-width;
                            height: parent.height;

                            hdr-eta-touch := TouchArea {
                                clicked => { root.sort-requested(7); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "ETA" + (root.sort-column == 7 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - Tokens.sp-3;
                            }
                        }

                        // Size
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width;
                            width: root.col-size-width;
                            height: parent.height;

                            hdr-size-touch := TouchArea {
                                clicked => { root.sort-requested(8); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Size" + (root.sort-column == 8 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - Tokens.sp-3;
                            }
                        }

                        // Ratio
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width + root.col-size-width;
                            width: root.col-ratio-width;
                            height: parent.height;

                            hdr-ratio-touch := TouchArea {
                                clicked => { root.sort-requested(9); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Ratio" + (root.sort-column == 9 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - Tokens.sp-3;
                            }
                        }

                        // Column separator lines (vertical)
                        Rectangle { x: root.col-name-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }
                        Rectangle { x: root.col-name-width + root.col-progress-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width + root.col-size-width - Tokens.border-width-thin; y: Tokens.sp-1; width: Tokens.border-width-thin; height: parent.height - Tokens.sp-2; background: Tokens.divider; }

                        // Header bottom border
                        Rectangle {
                            y: parent.height - Tokens.border-width-thin;
                            height: Tokens.border-width-thin;
                            background: Tokens.border-1;
                        }
                    }

                    // ── Torrent List (scrollable) ──
                    Flickable {
                        vertical-stretch: 1;
                        viewport-height: root.torrent-model.length * Tokens.row-h;

                        for item[index] in root.torrent-model: Rectangle {
                            y: index * Tokens.row-h;
                            height: Tokens.row-h;
                            width: parent.width;
                            background: item.selected
                                ? Tokens.accent
                                : (row-touch.has-hover
                                    ? Tokens.bg-hover
                                    : (mod(index, 2) == 0 ? Tokens.bg-0 : Tokens.bg-1));

                            row-touch := TouchArea {
                                clicked => {
                                    root.row-clicked(item.info-hash, root.shift-held, root.ctrl-held);
                                }
                                pointer-event(event) => {
                                    if event.kind == PointerEventKind.down && event.button == PointerEventButton.right {
                                        root.row-right-clicked(item.info-hash, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                                    }
                                }
                                mouse-cursor: pointer;
                            }

                            // Name
                            Text {
                                text: item.name;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                overflow: elide;
                                x: Tokens.sp-3;
                                width: root.col-name-width - Tokens.sp-5;
                            }

                            // Progress bar
                            TorrentProgressBar {
                                x: root.col-name-width + Tokens.sp-2;
                                y: (parent.height - Tokens.sp-6) / 2;
                                width: root.col-progress-width - Tokens.sp-4;
                                progress: item.progress;
                                fill-color: item.state-color;
                                progress-text: item.progress-text;
                            }

                            // State
                            Text {
                                text: item.state;
                                color: item.state-color;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                overflow: elide;
                                x: root.col-name-width + root.col-progress-width + Tokens.sp-2;
                                width: root.col-state-width - Tokens.sp-4;
                            }

                            // Down Rate
                            Text {
                                text: item.down-rate;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width;
                                width: root.col-down-rate-width - Tokens.sp-3;
                            }

                            // Up Rate
                            Text {
                                text: item.up-rate;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width;
                                width: root.col-up-rate-width - Tokens.sp-3;
                            }

                            // Seeds
                            Text {
                                text: item.seeds;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width;
                                width: root.col-seeds-width - Tokens.sp-3;
                            }

                            // Peers
                            Text {
                                text: item.peers;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width;
                                width: root.col-peers-width - Tokens.sp-3;
                            }

                            // ETA
                            Text {
                                text: item.eta;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width;
                                width: root.col-eta-width - Tokens.sp-3;
                            }

                            // Size
                            Text {
                                text: item.total-size;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width;
                                width: root.col-size-width - Tokens.sp-3;
                            }

                            // Ratio
                            Text {
                                text: item.ratio;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width + root.col-size-width;
                                width: root.col-ratio-width - Tokens.sp-3;
                            }

                            // Row bottom border
                            Rectangle {
                                y: parent.height - Tokens.border-width-thin;
                                width: parent.width;
                                height: Tokens.border-width-thin;
                                background: Tokens.divider;
                            }
                        }
                    }
                }

                // Error state
                if root.error-text != "": VerticalLayout {
                    alignment: center;
                    spacing: Tokens.sp-4;

                    Text {
                        text: "Error";
                        color: Tokens.status-error;
                        font-size: Tokens.fs-18;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: root.error-text;
                        color: Tokens.status-error;
                        font-size: Tokens.fs-14;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }

            // Status bar at bottom (visible when session ready)
            if root.session-ready: StatusBar {
                down-rate: root.status-down-rate;
                up-rate: root.status-up-rate;
                total-torrents: root.status-total-torrents;
                dht-nodes: root.status-dht-nodes;
                listen-port: root.status-listen-port;
            }
        }
    }

    // Toast overlay at bottom
    if root.toast-visible: Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - Tokens.sp-10 - Tokens.sp-7;
        width: Tokens.sp-10 * 10;
        height: Tokens.chrome-h;
        border-radius: Tokens.r-md;
        background: root.toast-is-error ? Tokens.status-error : Tokens.bg-2;
        border-color: root.toast-is-error ? Tokens.status-error : Tokens.border-1;
        border-width: Tokens.border-width-thin;

        Text {
            text: root.toast-text;
            color: Tokens.fg-0;
            font-size: Tokens.fs-13;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Add Magnet Dialog overlay
    AddMagnetDialog {
        show: root.show-add-magnet-dialog;
        default-dir: root.default-download-dir;
        width: root.width;
        height: root.height;
        add-confirmed(uri, dir) => {
            root.show-add-magnet-dialog = false;
            root.add-magnet-confirmed(uri, dir);
        }
        cancel => {
            root.show-add-magnet-dialog = false;
        }
        browse-download-dir => {
            root.browse-magnet-download-dir();
        }
    }

    // Add Torrent File Dialog overlay
    AddTorrentDialog {
        show: root.show-add-torrent-dialog;
        default-dir: root.default-download-dir;
        torrent-name: root.add-torrent-name;
        torrent-size: root.add-torrent-size;
        torrent-file-count: root.add-torrent-file-count;
        selected-file-path: root.add-torrent-file-path;
        width: root.width;
        height: root.height;
        add-confirmed(path, dir) => {
            root.show-add-torrent-dialog = false;
            root.add-torrent-confirmed(path, dir);
        }
        cancel => {
            root.show-add-torrent-dialog = false;
            root.add-torrent-file-path = "";
            root.add-torrent-name = "";
            root.add-torrent-size = "";
            root.add-torrent-file-count = 0;
        }
        browse-torrent-file => { root.browse-torrent-file(); }
        browse-download-dir => { root.browse-torrent-download-dir(); }
    }

    // Context Menu overlay (on top of everything)
    ContextMenu {
        show: root.show-context-menu;
        menu-x: root.context-menu-x;
        menu-y: root.context-menu-y;
        can-pause: root.ctx-can-pause;
        can-resume: root.ctx-can-resume;
        can-seed-only: root.ctx-can-seed-only;
        can-resume-download: root.ctx-can-resume-download;
        can-recheck: root.ctx-can-recheck;
        width: root.width;
        height: root.height;
        context-action(index) => {
            root.show-context-menu = false;
            root.context-action(index);
        }
        dismiss => {
            root.show-context-menu = false;
        }
    }

    // Delete Confirmation Dialog overlay (on top of context menu)
    ConfirmDeleteDialog {
        show: root.show-delete-dialog;
        count: root.delete-dialog-count;
        delete-files: root.delete-dialog-delete-files;
        width: root.width;
        height: root.height;
        delete-confirmed(delete-files) => {
            root.show-delete-dialog = false;
            root.delete-confirmed(delete-files);
        }
        cancel => {
            root.show-delete-dialog = false;
        }
    }

    // Tweaks overlay (Ctrl+Shift+T / Cmd+Shift+T)
    TweaksOverlay {
        show: root.show-tweaks;
        x: root.width - self.width - Tokens.sp-4;
        y: Tokens.sp-4;
        current-skin: root.current-skin;
        current-theme: root.current-theme;
        current-density: root.current-density;
        current-radius: root.current-radius;
        skin-changed(v)    => { root.tweaks-skin-changed(v); }
        theme-changed(v)   => { root.tweaks-theme-changed(v); }
        density-changed(v) => { root.tweaks-density-changed(v); }
        radius-changed(v)  => { root.tweaks-radius-changed(v); }
    }
}
