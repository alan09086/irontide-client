// IronTide GUI — dark-theme Slint scaffold (M162) + torrent list (M163)
// Custom widgets only — no std-widgets (hit-region issues on native backends).

import { Palette } from "palette.slint";
import { TorrentProgressBar } from "widgets/progress_bar.slint";
import { StatusBar } from "widgets/status_bar.slint";
import { AddMagnetDialog } from "widgets/add_magnet_dialog.slint";
import { AddTorrentDialog } from "widgets/add_torrent_dialog.slint";
import { ContextMenu } from "widgets/context_menu.slint";

export { Palette }

export struct TorrentRow {
    info-hash: string,
    name: string,
    total-size: string,
    progress: float,
    progress-text: string,
    down-rate: string,
    up-rate: string,
    seeds: string,
    peers: string,
    eta: string,
    state: string,
    state-color: color,
    ratio: string,
    selected: bool,
}

component MenuButton {
    in property <string> text;
    callback clicked();

    min-height: 30px;
    min-width: 60px;

    Rectangle {
        background: touch.has-hover ? Palette.menu-hover : Palette.menu-bg;
        border-radius: 2px;

        Text {
            text: root.text;
            color: Palette.text;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        touch := TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

component MenuBar {
    callback menu-file-action(int);

    height: 32px;

    Rectangle {
        background: Palette.menu-bg;
        border-width: 0px;

        HorizontalLayout {
            padding-left: 4px;
            spacing: 2px;
            alignment: start;

            file-btn := MenuButton {
                text: "File";
                clicked => { file-popup.show(); }
            }
        }
    }

    file-popup := PopupWindow {
        x: 4px;
        y: 32px;
        width: 180px;

        Rectangle {
            background: Palette.menu-bg;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 4px;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;

                // Item 0: Add Magnet...
                Rectangle {
                    height: 28px;
                    background: magnet-touch.has-hover ? Palette.menu-hover : Palette.menu-bg;
                    border-radius: 2px;

                    Text {
                        text: "Add Magnet...";
                        color: Palette.text;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: 8px;
                    }

                    magnet-touch := TouchArea {
                        clicked => { root.menu-file-action(0); }
                    }
                }

                // Item 1: Add Torrent File...
                Rectangle {
                    height: 28px;
                    background: torrent-touch.has-hover ? Palette.menu-hover : Palette.menu-bg;
                    border-radius: 2px;

                    Text {
                        text: "Add Torrent File...";
                        color: Palette.text;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: 8px;
                    }

                    torrent-touch := TouchArea {
                        clicked => { root.menu-file-action(1); }
                    }
                }

                // Separator
                Rectangle {
                    height: 1px;
                    background: Palette.border;
                }

                // Item 2: Quit
                Rectangle {
                    height: 28px;
                    background: quit-touch.has-hover ? Palette.menu-hover : Palette.menu-bg;
                    border-radius: 2px;

                    Text {
                        text: "Quit";
                        color: Palette.text;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: 8px;
                    }

                    quit-touch := TouchArea {
                        clicked => { root.menu-file-action(2); }
                    }
                }
            }
        }
    }
}

component Spinner {
    width: 32px;
    height: 32px;

    rect := Rectangle {
        width: 32px;
        height: 32px;
        border-radius: 4px;
        border-width: 3px;
        border-color: Palette.accent;
        background: transparent;
        clip: true;

        // Animated indicator bar
        indicator := Rectangle {
            x: -16px;
            y: 6px;
            width: 20px;
            height: 20px;
            border-radius: 10px;
            background: Palette.text;
            opacity: 0.6;

            animate x {
                duration: 1200ms;
                iteration-count: -1;
                easing: ease-in-out;
            }
        }
    }

    // Drive animation via states
    states [
        spinning when true: {
            indicator.x: 28px;
        }
    ]
}

export component MainWindow inherits Window {
    title: "IronTide";
    min-width: 700px;
    min-height: 400px;
    preferred-width: 900px;
    preferred-height: 600px;
    background: Palette.background;

    // ── Session state ──
    in-out property <bool> session-ready: false;
    in-out property <string> status-text: "";
    in-out property <string> error-text: "";
    in-out property <string> toast-text: "";
    in-out property <bool> toast-visible: false;
    in-out property <bool> toast-is-error: false;
    in-out property <string> default-download-dir: "";

    // ── Torrent model ──
    in-out property <[TorrentRow]> torrent-model;

    // ── Sort state ──
    in-out property <int> sort-column: 0;
    in-out property <bool> sort-ascending: true;

    // ── Status bar ──
    in-out property <string> status-down-rate: "\u{2014}";
    in-out property <string> status-up-rate: "\u{2014}";
    in-out property <int> status-total-torrents: 0;
    in-out property <int> status-dht-nodes: 0;
    in-out property <int> status-listen-port: 0;

    // ── Modifier tracking ──
    in-out property <bool> shift-held: false;
    in-out property <bool> ctrl-held: false;

    // ── Column widths (set from Rust, used for layout) ──
    // Fixed columns: Progress(120) + State(90) + DownRate(80) + UpRate(80) +
    //                Seeds(50) + Peers(50) + Eta(70) + Size(80) + Ratio(60) = 680px
    // Name gets the rest. These are the defaults; Rust can override.
    in-out property <length> col-name-width: root.width > 780px ? root.width - 680px : 100px;
    in-out property <length> col-progress-width: 120px;
    in-out property <length> col-state-width: 90px;
    in-out property <length> col-down-rate-width: 80px;
    in-out property <length> col-up-rate-width: 80px;
    in-out property <length> col-seeds-width: 50px;
    in-out property <length> col-peers-width: 50px;
    in-out property <length> col-eta-width: 70px;
    in-out property <length> col-size-width: 80px;
    in-out property <length> col-ratio-width: 60px;

    // ── Add Magnet Dialog ──
    in-out property <bool> show-add-magnet-dialog: false;
    callback add-magnet-confirmed(string, string);
    callback browse-magnet-download-dir();

    // ── Add Torrent Dialog ──
    in-out property <bool> show-add-torrent-dialog: false;
    in-out property <string> add-torrent-file-path: "";
    in-out property <string> add-torrent-name: "";
    in-out property <string> add-torrent-size: "";
    in-out property <int> add-torrent-file-count: 0;
    callback add-torrent-confirmed(string, string);
    callback browse-torrent-file();
    callback browse-torrent-download-dir();

    // ── Context Menu ──
    in-out property <bool> show-context-menu: false;
    in-out property <length> context-menu-x: 0px;
    in-out property <length> context-menu-y: 0px;
    in-out property <bool> ctx-can-pause: true;
    in-out property <bool> ctx-can-resume: true;
    in-out property <bool> ctx-can-seed-only: true;
    in-out property <bool> ctx-can-resume-download: true;
    in-out property <bool> ctx-can-recheck: true;
    callback context-action(int);
    callback row-right-clicked(/* info-hash */ string, /* x */ length, /* y */ length);

    // ── Callbacks ──
    callback menu-file-action(int);
    callback quit-requested();
    callback sort-requested(/* column index */ int);
    callback row-clicked(/* info-hash */ string, /* shift */ bool, /* ctrl */ bool);

    // ── FocusScope for modifier key tracking ──
    focus-scope := FocusScope {
        key-pressed(event) => {
            if event.text == Key.Shift {
                root.shift-held = true;
            }
            if event.text == Key.Control {
                root.ctrl-held = true;
            }
            accept
        }
        key-released(event) => {
            if event.text == Key.Shift {
                root.shift-held = false;
            }
            if event.text == Key.Control {
                root.ctrl-held = false;
            }
            accept
        }

        VerticalLayout {
            // Menu bar at top
            menu := MenuBar {
                menu-file-action(index) => {
                    root.menu-file-action(index);
                }
            }

            // Main content area
            Rectangle {
                background: Palette.background;
                vertical-stretch: 1;

                // Loading state: spinner + message
                if !root.session-ready && root.error-text == "": VerticalLayout {
                    alignment: center;

                    HorizontalLayout {
                        alignment: center;
                        Spinner { }
                    }

                    Text {
                        text: "Starting session...";
                        color: Palette.disabled-text;
                        font-size: 16px;
                        horizontal-alignment: center;
                    }
                }

                // Ready state with empty model: empty placeholder
                if root.session-ready && root.error-text == "" && root.torrent-model.length == 0: VerticalLayout {
                    alignment: center;
                    spacing: 8px;

                    Text {
                        text: "No torrents yet.";
                        color: Palette.text;
                        font-size: 20px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Use File > Add Magnet to get started.";
                        color: Palette.disabled-text;
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                }

                // Ready state with torrents: table header + list
                if root.session-ready && root.error-text == "" && root.torrent-model.length > 0: VerticalLayout {
                    spacing: 0px;

                    // ── Table Header ──
                    Rectangle {
                        height: 24px;
                        background: Palette.surface;

                        // Name
                        Rectangle {
                            x: 0px;
                            width: root.col-name-width;
                            height: parent.height;

                            hdr-name-touch := TouchArea {
                                clicked => { root.sort-requested(0); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Name" + (root.sort-column == 0 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                x: 6px;
                            }
                        }

                        // Progress
                        Rectangle {
                            x: root.col-name-width;
                            width: root.col-progress-width;
                            height: parent.height;

                            hdr-progress-touch := TouchArea {
                                clicked => { root.sort-requested(1); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Progress" + (root.sort-column == 1 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                x: 4px;
                            }
                        }

                        // State
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width;
                            width: root.col-state-width;
                            height: parent.height;

                            hdr-state-touch := TouchArea {
                                clicked => { root.sort-requested(2); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "State" + (root.sort-column == 2 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                x: 4px;
                            }
                        }

                        // Down Rate
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width;
                            width: root.col-down-rate-width;
                            height: parent.height;

                            hdr-down-rate-touch := TouchArea {
                                clicked => { root.sort-requested(3); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "\u{2193}" + (root.sort-column == 3 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - 6px;
                            }
                        }

                        // Up Rate
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width;
                            width: root.col-up-rate-width;
                            height: parent.height;

                            hdr-up-rate-touch := TouchArea {
                                clicked => { root.sort-requested(4); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "\u{2191}" + (root.sort-column == 4 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - 6px;
                            }
                        }

                        // Seeds
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width;
                            width: root.col-seeds-width;
                            height: parent.height;

                            hdr-seeds-touch := TouchArea {
                                clicked => { root.sort-requested(5); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Seeds" + (root.sort-column == 5 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - 6px;
                            }
                        }

                        // Peers
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width;
                            width: root.col-peers-width;
                            height: parent.height;

                            hdr-peers-touch := TouchArea {
                                clicked => { root.sort-requested(6); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Peers" + (root.sort-column == 6 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - 6px;
                            }
                        }

                        // ETA
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width;
                            width: root.col-eta-width;
                            height: parent.height;

                            hdr-eta-touch := TouchArea {
                                clicked => { root.sort-requested(7); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "ETA" + (root.sort-column == 7 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - 6px;
                            }
                        }

                        // Size
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width;
                            width: root.col-size-width;
                            height: parent.height;

                            hdr-size-touch := TouchArea {
                                clicked => { root.sort-requested(8); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Size" + (root.sort-column == 8 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - 6px;
                            }
                        }

                        // Ratio
                        Rectangle {
                            x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width + root.col-size-width;
                            width: root.col-ratio-width;
                            height: parent.height;

                            hdr-ratio-touch := TouchArea {
                                clicked => { root.sort-requested(9); }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Ratio" + (root.sort-column == 9 ? (root.sort-ascending ? " \u{25B2}" : " \u{25BC}") : "");
                                color: Palette.text;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: 0;
                                width: parent.width - 6px;
                            }
                        }

                        // Column separator lines (vertical)
                        Rectangle { x: root.col-name-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }
                        Rectangle { x: root.col-name-width + root.col-progress-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }
                        Rectangle { x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width + root.col-size-width - 1px; y: 2px; width: 1px; height: parent.height - 4px; background: Palette.col-separator; }

                        // Header bottom border
                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            background: Palette.border;
                        }
                    }

                    // ── Torrent List (scrollable) ──
                    Flickable {
                        vertical-stretch: 1;
                        viewport-height: root.torrent-model.length * 28px;

                        for item[index] in root.torrent-model: Rectangle {
                            y: index * 28px;
                            height: 28px;
                            width: parent.width;
                            background: item.selected
                                ? Palette.accent
                                : (row-touch.has-hover
                                    ? Palette.menu-hover
                                    : (mod(index, 2) == 0 ? Palette.background : Palette.row-alt));

                            row-touch := TouchArea {
                                clicked => {
                                    root.row-clicked(item.info-hash, root.shift-held, root.ctrl-held);
                                }
                                pointer-event(event) => {
                                    if event.kind == PointerEventKind.down && event.button == PointerEventButton.right {
                                        root.row-right-clicked(item.info-hash, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                                    }
                                }
                                mouse-cursor: pointer;
                            }

                            // Name
                            Text {
                                text: item.name;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                overflow: elide;
                                x: 6px;
                                width: root.col-name-width - 12px;
                            }

                            // Progress bar
                            TorrentProgressBar {
                                x: root.col-name-width + 4px;
                                y: (parent.height - 14px) / 2;
                                width: root.col-progress-width - 8px;
                                progress: item.progress;
                                fill-color: item.state-color;
                                progress-text: item.progress-text;
                            }

                            // State
                            Text {
                                text: item.state;
                                color: item.state-color;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                overflow: elide;
                                x: root.col-name-width + root.col-progress-width + 4px;
                                width: root.col-state-width - 8px;
                            }

                            // Down Rate
                            Text {
                                text: item.down-rate;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width;
                                width: root.col-down-rate-width - 6px;
                            }

                            // Up Rate
                            Text {
                                text: item.up-rate;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width;
                                width: root.col-up-rate-width - 6px;
                            }

                            // Seeds
                            Text {
                                text: item.seeds;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width;
                                width: root.col-seeds-width - 6px;
                            }

                            // Peers
                            Text {
                                text: item.peers;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width;
                                width: root.col-peers-width - 6px;
                            }

                            // ETA
                            Text {
                                text: item.eta;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width;
                                width: root.col-eta-width - 6px;
                            }

                            // Size
                            Text {
                                text: item.total-size;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width;
                                width: root.col-size-width - 6px;
                            }

                            // Ratio
                            Text {
                                text: item.ratio;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                                x: root.col-name-width + root.col-progress-width + root.col-state-width + root.col-down-rate-width + root.col-up-rate-width + root.col-seeds-width + root.col-peers-width + root.col-eta-width + root.col-size-width;
                                width: root.col-ratio-width - 6px;
                            }

                            // Row bottom border
                            Rectangle {
                                y: parent.height - 1px;
                                width: parent.width;
                                height: 1px;
                                background: Palette.col-separator;
                            }
                        }
                    }
                }

                // Error state
                if root.error-text != "": VerticalLayout {
                    alignment: center;
                    spacing: 8px;

                    Text {
                        text: "Error";
                        color: #ff4444;
                        font-size: 20px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: root.error-text;
                        color: #ff6666;
                        font-size: 14px;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }

            // Status bar at bottom (visible when session ready)
            if root.session-ready: StatusBar {
                down-rate: root.status-down-rate;
                up-rate: root.status-up-rate;
                total-torrents: root.status-total-torrents;
                dht-nodes: root.status-dht-nodes;
                listen-port: root.status-listen-port;
            }
        }
    }

    // Toast overlay at bottom
    if root.toast-visible: Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - 60px;
        width: 400px;
        height: 36px;
        border-radius: 6px;
        background: root.toast-is-error ? Palette.danger : Palette.surface;
        border-color: root.toast-is-error ? Palette.danger : Palette.border;
        border-width: 1px;

        Text {
            text: root.toast-text;
            color: Palette.text;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Add Magnet Dialog overlay
    AddMagnetDialog {
        show: root.show-add-magnet-dialog;
        default-dir: root.default-download-dir;
        width: root.width;
        height: root.height;
        add-confirmed(uri, dir) => {
            root.show-add-magnet-dialog = false;
            root.add-magnet-confirmed(uri, dir);
        }
        cancel => {
            root.show-add-magnet-dialog = false;
        }
        browse-download-dir => {
            root.browse-magnet-download-dir();
        }
    }

    // Add Torrent File Dialog overlay
    AddTorrentDialog {
        show: root.show-add-torrent-dialog;
        default-dir: root.default-download-dir;
        torrent-name: root.add-torrent-name;
        torrent-size: root.add-torrent-size;
        torrent-file-count: root.add-torrent-file-count;
        selected-file-path: root.add-torrent-file-path;
        width: root.width;
        height: root.height;
        add-confirmed(path, dir) => {
            root.show-add-torrent-dialog = false;
            root.add-torrent-confirmed(path, dir);
        }
        cancel => {
            root.show-add-torrent-dialog = false;
            root.add-torrent-file-path = "";
            root.add-torrent-name = "";
            root.add-torrent-size = "";
            root.add-torrent-file-count = 0;
        }
        browse-torrent-file => { root.browse-torrent-file(); }
        browse-download-dir => { root.browse-torrent-download-dir(); }
    }

    // Context Menu overlay (on top of everything)
    ContextMenu {
        show: root.show-context-menu;
        menu-x: root.context-menu-x;
        menu-y: root.context-menu-y;
        can-pause: root.ctx-can-pause;
        can-resume: root.ctx-can-resume;
        can-seed-only: root.ctx-can-seed-only;
        can-resume-download: root.ctx-can-resume-download;
        can-recheck: root.ctx-can-recheck;
        width: root.width;
        height: root.height;
        context-action(index) => {
            root.show-context-menu = false;
            root.context-action(index);
        }
        dismiss => {
            root.show-context-menu = false;
        }
    }
}
