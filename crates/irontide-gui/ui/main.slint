// IronTide GUI — dark-theme Slint scaffold (M162) + torrent list (M163)
// Custom widgets only — no std-widgets (hit-region issues on native backends).
// Retrofitted to the Tokens design-system globals in M172b Lane B.
// Single layout: L1 (3-pane) — sidebar | (torrent list / detail pane).
// L2 (drawer) and L3 (command workspace) removed.

import { Tokens, Shadow } from "tokens.slint";
import { StatusBar } from "widgets/status_bar.slint";
import { AddMagnetDialog } from "widgets/add_magnet_dialog.slint";
import { AddTorrentDialog } from "widgets/add_torrent_dialog.slint";
import { ContextMenu } from "widgets/context_menu.slint";
import { ConfirmDeleteDialog } from "widgets/confirm_delete_dialog.slint";
import { PreferencesDialog } from "organisms/preferences_dialog.slint";
// M173 Lane A: sidebar IA. The `Sidebar` organism + the `SidebarRow`
// data struct are imported here so slint_build picks them up. The
// MainWindow body (below) wires the `Sidebar` into the layout in task
// A8.
import { Sidebar, SidebarRow } from "organisms/sidebar.slint";
// M176: TorrentListView extracted into its own organism so M177–M178
// can render it inside the detail-tabs container with `compact-mode`.
import { TorrentListView, TorrentRow } from "organisms/torrent_list.slint";
// Toolbar import removed — L2/L3 layout buttons no longer needed.
// M177: DetailPane organism + FileTreeRow data struct. Replaces the
// M176 placeholder text in all three layouts (L1 inline / L2 drawer /
// L3 popover). Step 4 lights up the populated tab body.
import { DetailPane, FileTreeRow, PeerRow, TrackerRow, WebSeedRow } from "organisms/detail_pane.slint";
import { FilePriorityPopup } from "molecules/file_priority_popup.slint";
import { CommandPalette, PaletteItem, PaletteCategory } from "organisms/command_palette.slint";

export { Tokens, Shadow, SidebarRow, TorrentRow, FileTreeRow, PaletteItem, PaletteCategory }

component MenuButton {
    in property <string> text;
    callback clicked();

    min-height: Tokens.sp-9 - Tokens.sp-1;
    min-width: Tokens.sp-10 + Tokens.sp-7;

    Rectangle {
        background: touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
        border-radius: Tokens.r-sm;

        Text {
            text: root.text;
            color: Tokens.fg-0;
            font-size: Tokens.fs-13;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        touch := TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

component MenuBar {
    callback menu-file-action(int);

    height: Tokens.chrome-h;

    Rectangle {
        background: Tokens.bg-1;
        border-width: 0;

        HorizontalLayout {
            padding-left: Tokens.sp-2;
            spacing: Tokens.sp-1;
            alignment: start;

            file-btn := MenuButton {
                text: "File";
                clicked => { file-popup.show(); }
            }
        }
    }

    file-popup := PopupWindow {
        x: Tokens.sp-2;
        y: Tokens.chrome-h;
        width: Tokens.sidebar-w;

        Rectangle {
            background: Tokens.bg-1;
            border-color: Tokens.border-1;
            border-width: Tokens.border-width-thin;
            border-radius: Tokens.r-md;

            VerticalLayout {
                padding: Tokens.sp-2;
                spacing: Tokens.sp-1;

                // Item 0: Add Magnet...
                Rectangle {
                    height: Tokens.row-h;
                    background: magnet-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Add Magnet...";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: Tokens.sp-4;
                    }

                    magnet-touch := TouchArea {
                        clicked => { root.menu-file-action(0); }
                    }
                }

                // Item 1: Add Torrent File...
                Rectangle {
                    height: Tokens.row-h;
                    background: torrent-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Add Torrent File...";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: Tokens.sp-4;
                    }

                    torrent-touch := TouchArea {
                        clicked => { root.menu-file-action(1); }
                    }
                }

                // Item 2: Preferences...
                Rectangle {
                    height: Tokens.row-h;
                    background: prefs-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    HorizontalLayout {
                        padding-left: Tokens.sp-4;
                        padding-right: Tokens.sp-4;

                        Text {
                            text: "Preferences\u{2026}";
                            color: Tokens.fg-0;
                            font-size: Tokens.fs-13;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                            horizontal-stretch: 1;
                        }

                        Text {
                            text: "Ctrl+,";
                            color: Tokens.fg-3;
                            font-size: Tokens.fs-13;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                    }

                    prefs-touch := TouchArea {
                        clicked => { root.menu-file-action(2); }
                    }
                }

                // Separator
                Rectangle {
                    height: Tokens.border-width-thin;
                    background: Tokens.border-1;
                }

                // Item 3: Quit
                Rectangle {
                    height: Tokens.row-h;
                    background: quit-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Quit";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: Tokens.sp-4;
                    }

                    quit-touch := TouchArea {
                        clicked => { root.menu-file-action(3); }
                    }
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "IronTide";
    min-width: Tokens.win-min-width;
    min-height: Tokens.win-min-height;
    preferred-width: Tokens.win-preferred-width;
    preferred-height: Tokens.win-preferred-height;
    background: Tokens.bg-0;

    // ── Skin gate (M172b Lane A + B) ──
    // Set to true by Rust after SkinSettings::apply populates Tokens.
    // Until then, the main chrome is hidden and a minimal spinner shown.
    in-out property <bool> skin-applied: false;

    // ── Session state ──
    in-out property <bool> session-ready: false;
    in-out property <string> status-text: "";
    in-out property <string> error-text: "";
    in-out property <string> toast-text: "";
    in-out property <bool> toast-visible: false;
    in-out property <bool> toast-is-error: false;
    in-out property <string> default-download-dir: "";

    // ── Torrent model ──
    in-out property <[TorrentRow]> torrent-model;

    // ── Detail pane (M177) ──
    // Primary selection — drives which torrent the detail pane fetches.
    // Empty string ("") means deselected → render the empty state.
    // Pushed by Rust via `update_primary_selection` (selection
    // callbacks) and by the poll-loop detail-snapshot path. The
    // DetailPane organism reads `info-hash` bound from this property.
    in-out property <string> detail-info-hash: "";
    // Active detail-pane tab. `"General"` (default) or `"Content"`.
    // Survives `if`-branch re-mount when the user toggles layout. The
    // poll loop's per-tick `file_priorities` + `file_progress` fetches
    // are gated on `"Content"` (D-eng-2).
    in-out property <string> detail-active-tab: "General";

    // ── Detail header / Transfer / Info block (filled by poll loop) ──
    in-out property <string> detail-name: "";
    in-out property <string> detail-error: "";
    in-out property <string> detail-state-label: "";
    in-out property <string> detail-down-rate: "\u{2014}";
    in-out property <string> detail-up-rate: "\u{2014}";
    in-out property <string> detail-all-time-down: "0 B";
    in-out property <string> detail-all-time-up: "0 B";
    in-out property <string> detail-ratio: "0.00";
    in-out property <string> detail-eta: "\u{2014}";
    in-out property <string> detail-num-peers: "0 / 0";
    in-out property <string> detail-num-seeds: "0";
    in-out property <string> detail-share-fraction: "—";
    in-out property <string> detail-save-path: "";
    in-out property <string> detail-total-size: "";
    in-out property <string> detail-piece-count-text: "";
    in-out property <string> detail-piece-size: "";
    in-out property <string> detail-added-time: "";
    in-out property <string> detail-last-seen-complete: "";
    in-out property <string> detail-active-duration: "";

    // ── Heatmap ──
    in-out property <[int]> detail-piece-buckets: [];
    in-out property <string> detail-pieces-text: "0 / 0 pieces (0%)";

    // ── Content tab ──
    in-out property <bool> detail-sequential: false;
    in-out property <[FileTreeRow]> detail-files: [];

    // ── M178: Peers / Trackers / HTTP Sources tabs ──
    in-out property <[PeerRow]> detail-peers: [];
    in-out property <[TrackerRow]> detail-trackers: [];
    in-out property <[WebSeedRow]> detail-http-sources: [];

    // ── M180: Speed tab ──
    in-out property <string> detail-speed-dl-path: "";
    in-out property <string> detail-speed-ul-path: "";
    in-out property <string> detail-speed-max-rate: "\u{2014}";
    in-out property <string> detail-speed-current-dl: "\u{2014}";
    in-out property <string> detail-speed-current-ul: "\u{2014}";
    in-out property <string> detail-speed-dl-limit: "0";
    in-out property <string> detail-speed-ul-limit: "0";
    in-out property <string> detail-speed-elapsed: "";
    callback detail-speed-dl-limit-applied(/* value */ string);
    callback detail-speed-ul-limit-applied(/* value */ string);

    // ── M178: file-priority popup state (custom-overlay pattern) ──
    in-out property <bool> show-file-priority-popup: false;
    in-out property <length> file-priority-popup-x: 0px;
    in-out property <length> file-priority-popup-y: 0px;

    // ── Detail-pane callbacks (Step 6) ──
    callback detail-tab-changed(/* tab label */ string);
    // The folder key is `"{info_hash}/{folder_path}"`. Rust toggles
    // membership in `AppState.detail_expanded` (semantically tracking
    // the *collapsed* set per the M177 plan).
    callback detail-folder-toggled(/* folder key */ string);
    callback detail-sequential-toggled(/* enabled */ bool);
    // M178: per-file selection + priority popup signals.
    callback detail-file-clicked(/* index */ int, /* ctrl */ bool, /* shift */ bool);
    callback detail-file-right-clicked(/* index */ int, /* x */ length, /* y */ length);
    // F9: folder-level priority targeting.
    callback detail-folder-right-clicked(/* key */ string, /* x */ length, /* y */ length);
    callback detail-reannounce(/* tracker url */ string);
    callback file-priority-selected(/* priority repr */ int);
    callback file-priority-dismissed();

    // ── Sort state ──
    in-out property <int> sort-column: 0;
    in-out property <bool> sort-ascending: true;

    // ── Status bar ──
    in-out property <string> status-down-rate: "\u{2014}";
    in-out property <string> status-up-rate: "\u{2014}";
    in-out property <int> status-total-torrents: 0;
    in-out property <int> status-dht-nodes: 0;
    in-out property <int> status-listen-port: 0;

    // ── Modifier tracking ──
    in-out property <bool> shift-held: false;
    in-out property <bool> ctrl-held: false;
    in-out property <bool> meta-held: false;

    // ── Column widths (set from Rust, used for layout) ──
    // Fixed columns: Progress + State + DownRate + UpRate + Seeds + Peers
    //                + Eta + Size + Ratio; Name gets the remaining space.
    // Defaults come from the `Tokens.col-default-*` fallbacks so no
    // literal px values leak into main.slint — Rust overrides these from
    // the persisted GuiConfig on startup.
    in-out property <length> col-name-width:
        root.width > Tokens.col-width-threshold
            ? root.width - Tokens.col-width-non-name-total
            : Tokens.col-default-name;
    in-out property <length> col-progress-width: Tokens.col-default-progress;
    in-out property <length> col-state-width: Tokens.col-default-state;
    in-out property <length> col-down-rate-width: Tokens.col-default-rate;
    in-out property <length> col-up-rate-width: Tokens.col-default-rate;
    in-out property <length> col-seeds-width: Tokens.col-default-count;
    in-out property <length> col-peers-width: Tokens.col-default-count;
    in-out property <length> col-eta-width: Tokens.col-default-eta;
    in-out property <length> col-size-width: Tokens.col-default-rate;
    in-out property <length> col-ratio-width: Tokens.col-default-ratio;

    // ── Add Magnet Dialog ──
    in-out property <bool> show-add-magnet-dialog: false;
    callback add-magnet-confirmed(string, string);
    callback browse-magnet-download-dir();

    // ── Add Torrent Dialog ──
    in-out property <bool> show-add-torrent-dialog: false;
    in-out property <string> add-torrent-file-path: "";
    in-out property <string> add-torrent-name: "";
    in-out property <string> add-torrent-size: "";
    in-out property <int> add-torrent-file-count: 0;
    callback add-torrent-confirmed(string, string);
    callback browse-torrent-file();
    callback browse-torrent-download-dir();

    // ── Context Menu ──
    in-out property <bool> show-context-menu: false;
    in-out property <length> context-menu-x: 0;
    in-out property <length> context-menu-y: 0;
    in-out property <bool> ctx-can-pause: true;
    in-out property <bool> ctx-can-resume: true;
    in-out property <bool> ctx-can-seed-only: true;
    in-out property <bool> ctx-can-resume-download: true;
    in-out property <bool> ctx-can-recheck: true;
    callback context-action(int);
    callback row-right-clicked(/* info-hash */ string, /* x */ length, /* y */ length);

    // ── Delete Confirmation Dialog ──
    in-out property <bool> show-delete-dialog: false;
    in-out property <int> delete-dialog-count: 0;
    in-out property <bool> delete-dialog-delete-files: false;
    callback delete-confirmed(/* delete_files */ bool);

    // ── Keyboard shortcuts ──
    callback toggle-pause-resume();
    callback delete-selected();
    callback select-all();
    callback show-details-stub();
    // M173 Lane A: Ctrl+1..9 / Cmd+1..9 sidebar shortcuts. The payload
    // is the raw digit text (`"1"`..`"9"`); Rust validates the
    // platform accelerator via `accel::parse_sidebar_shortcut` against
    // `ctrl-held` / `meta-held` and resolves the slot against the
    // visible sidebar order in `AppState`. Fires only when no
    // modal/menu has focus (focus-scope isolation — see the gate in
    // the FocusScope handler below).
    callback sidebar-shortcut(/* digit text "1".."9" */ string);

    // ── Sidebar (M173 Lane A task A8) ──
    in property <[SidebarRow]> sidebar-library-rows;
    in property <[SidebarRow]> sidebar-category-rows;
    in property <[SidebarRow]> sidebar-tag-rows;
    in property <[SidebarRow]> sidebar-tracker-rows;
    in-out property <bool> sidebar-library-collapsed: false;
    in-out property <bool> sidebar-category-collapsed: false;
    in-out property <bool> sidebar-tag-collapsed: false;
    in-out property <bool> sidebar-tracker-collapsed: false;
    callback sidebar-predicate-changed(/* token */ string);
    callback sidebar-section-toggled(/* kind: library|category|tag|tracker */ string, /* collapsed */ bool);

    // ── Preferences dialog (M184, replaces Tweaks overlay) ──
    in-out property <bool> show-preferences-dialog: false;
    in-out property <string> pref-skin: "tide";
    in-out property <string> pref-theme: "dark";
    in-out property <string> pref-density: "balanced";
    in-out property <string> pref-radius: "balanced";
    in-out property <bool> pref-confirm-delete: true;
    in-out property <bool> pref-confirm-pause-all: false;
    in-out property <bool> pref-show-torrent-added-toast: true;
    in-out property <string> pref-double-click-action: "Show Details";
    in-out property <bool> pref-start-minimized: false;
    in-out property <bool> pref-minimize-to-tray: false;
    in-out property <bool> pref-resume-previous-session: true;
    in-out property <bool> pref-notify-on-complete: true;
    in-out property <bool> pref-notify-on-error: true;
    in-out property <bool> pref-notify-on-rss: false;
    in-out property <bool> pref-play-sound-on-complete: false;
    in-out property <string> pref-on-complete-program: "";
    in-out property <string> pref-download-dir: "";
    in-out property <bool> pref-use-incomplete-dir: false;
    in-out property <string> pref-incomplete-dir: "";
    in-out property <bool> pref-create-subfolder: true;
    in-out property <bool> pref-pre-allocate: false;
    in-out property <bool> pref-show-add-torrent-dialog: true;
    in-out property <bool> pref-skip-hash-check: false;
    in-out property <bool> pref-incomplete-extension: false;
    in-out property <bool> pref-use-auto-categories: false;
    in-out property <bool> pref-append-date-to-path: false;
    in-out property <string> pref-watched-folder: "";
    in-out property <string> pref-copy-torrent-to: "";
    in-out property <bool> pref-delete-torrent-after-add: false;
    in-out property <bool> pref-move-completed-enabled: false;
    in-out property <string> pref-move-completed-to: "";
    in-out property <string> pref-dl-on-complete-program: "";
    // ── M185: Connection tab ──
    in-out property <string> pref-listen-port: "42020";
    in-out property <bool> pref-randomize-port: false;
    in-out property <bool> pref-enable-upnp: true;
    in-out property <bool> pref-enable-natpmp: true;
    in-out property <string> pref-max-connections-global: "-1";
    in-out property <string> pref-max-peers-per-torrent: "128";
    in-out property <string> pref-max-upload-slots-global: "-1";
    in-out property <string> pref-max-upload-slots-per-torrent: "4";
    in-out property <string> pref-active-downloads: "3";
    in-out property <string> pref-active-seeds: "5";
    in-out property <string> pref-active-limit: "500";
    in-out property <string> pref-proxy-type: "None";
    in-out property <string> pref-proxy-host: "";
    in-out property <string> pref-proxy-port: "0";
    in-out property <bool> pref-proxy-peer-connections: true;
    in-out property <bool> pref-proxy-hostnames: true;
    in-out property <bool> pref-ip-filter-enabled: false;
    in-out property <string> pref-ip-filter-path: "";
    in-out property <bool> pref-ip-filter-auto-refresh: false;
    // ── M185: Speed tab ──
    in-out property <bool> pref-dl-limit-enabled: false;
    in-out property <string> pref-dl-limit-value: "0";
    in-out property <bool> pref-ul-limit-enabled: false;
    in-out property <string> pref-ul-limit-value: "0";
    in-out property <string> pref-alt-dl-limit: "0";
    in-out property <string> pref-alt-ul-limit: "0";
    in-out property <bool> pref-alt-speed-enabled: false;
    in-out property <bool> pref-rate-limit-overhead: true;
    in-out property <bool> pref-rate-limit-utp: true;
    in-out property <bool> pref-rate-limit-lan: false;
    // ── M187: BitTorrent tab ──
    in-out property <bool> pref-enable-dht: true;
    in-out property <bool> pref-enable-pex: true;
    in-out property <bool> pref-enable-lsd: true;
    in-out property <string> pref-encryption-mode: "Disable encryption";
    in-out property <bool> pref-anonymous-mode: false;
    in-out property <bool> pref-seed-ratio-enabled: false;
    in-out property <string> pref-seed-ratio-value: "2.00";
    in-out property <string> pref-max-ratio-action: "Pause torrent";
    in-out property <bool> pref-seed-time-enabled: false;
    in-out property <string> pref-seed-time-value: "1440";
    in-out property <bool> pref-inactive-seed-time-enabled: false;
    in-out property <string> pref-inactive-seed-time-value: "60";
    in-out property <bool> pref-queueing-enabled: false;
    // ── M187: RSS tab ──
    in-out property <bool> pref-rss-enabled: false;
    in-out property <string> pref-rss-refresh-interval: "15";
    in-out property <string> pref-rss-max-articles: "50";
    in-out property <bool> pref-rss-auto-download: false;
    in-out property <bool> pref-rss-smart-filter: false;
    in-out property <bool> pref-rss-download-repacks: false;
    // ── M187: Web UI tab ──
    in-out property <bool> pref-webui-enabled: true;
    in-out property <string> pref-webui-bind: "";
    in-out property <string> pref-webui-port: "";
    in-out property <bool> pref-webui-https: false;
    in-out property <string> pref-webui-username: "admin";
    in-out property <bool> pref-webui-bypass-local-auth: false;
    in-out property <string> pref-webui-session-ttl: "86400";
    in-out property <string> pref-webui-max-failed-auth: "5";
    in-out property <string> pref-webui-ban-duration: "3600";
    in-out property <bool> pref-webui-csrf: true;
    in-out property <bool> pref-webui-host-validation: true;
    in-out property <bool> pref-webui-reverse-proxy: false;
    in-out property <bool> pref-ddns-enabled: false;
    in-out property <string> pref-ddns-service: "";
    in-out property <string> pref-ddns-domain: "";
    // ── M187: Advanced tab ──
    in-out property <string> pref-hashing-threads: "4";
    in-out property <string> pref-save-resume-interval: "5";
    in-out property <string> pref-storage-mode: "Auto";
    in-out property <string> pref-disk-cache-size: "-1";
    in-out property <bool> pref-enable-utp: true;
    in-out property <bool> pref-enable-fast-ext: true;
    in-out property <bool> pref-enable-holepunch: true;
    in-out property <bool> pref-enable-bep40: true;
    in-out property <string> pref-config-path: "";
    in-out property <bool> pref-dirty: false;
    callback preferences-apply-requested();
    callback preferences-cancel-requested();
    callback preferences-ok-requested();
    callback preferences-browse-download-dir();
    callback preferences-browse-incomplete-dir();
    callback preferences-browse-watched-folder();
    callback preferences-browse-copy-torrent-to();
    callback preferences-browse-move-completed-to();

    // ── Layout (L1 / 3-pane only — L2/L3 removed) ──

    public function close-preferences() {
        root.show-preferences-dialog = false;
    }

    // ── Command Palette (M183) ──
    in-out property <bool> show-command-palette: false;
    in property <[PaletteCategory]> palette-categories;
    in-out property <int> palette-active-index: 0;
    in property <int> palette-total-count: 0;
    callback palette-query-changed(string);
    callback palette-item-selected(int);
    callback palette-dismissed();

    // ── Callbacks ──
    callback menu-file-action(int);
    callback quit-requested();
    callback sort-requested(/* column index */ int);
    callback row-clicked(/* info-hash */ string, /* shift */ bool, /* ctrl */ bool);

    // ── FocusScope for keyboard shortcuts + modifier key tracking ──
    focus-scope := FocusScope {
        key-pressed(event) => {
            // Ctrl+, (Cmd+, on macOS): open Preferences dialog.
            if !root.shift-held
               && (root.ctrl-held || root.meta-held)
               && event.text == "," {
                root.show-preferences-dialog = true;
                return accept;
            }
            // Ctrl+Shift+P (Cmd+Shift+P on macOS): open Preferences dialog.
            if root.shift-held
               && (root.ctrl-held || root.meta-held)
               && (event.text == "p" || event.text == "P") {
                root.show-preferences-dialog = true;
                return accept;
            }
            // Ctrl+K (Cmd+K on macOS): toggle command palette.
            if !root.shift-held
               && (root.ctrl-held || root.meta-held)
               && (event.text == "k" || event.text == "K") {
                root.show-command-palette = !root.show-command-palette;
                if root.show-command-palette {
                    root.palette-query-changed("");
                }
                return accept;
            }
            // Keyboard shortcuts (only when no dialog/menu is open).
            // The Tweaks overlay is treated as modal too — it absorbs
            // its own keys above, so any leftover key event with
            // root.show-tweaks should not trigger sidebar shortcuts.
            if !root.show-add-magnet-dialog && !root.show-add-torrent-dialog && !root.show-delete-dialog && !root.show-context-menu && !root.show-preferences-dialog && !root.show-command-palette {
                if event.text == " " {
                    root.toggle-pause-resume();
                    return accept;
                }
                if event.text == Key.Delete {
                    root.delete-selected();
                    return accept;
                }
                if event.text == Key.Return {
                    root.show-details-stub();
                    return accept;
                }
                if event.text == "a" && root.ctrl-held {
                    root.select-all();
                    return accept;
                }
                // M173 Lane A: Ctrl+1..9 (Cmd+1..9 on macOS) — sidebar
                // shortcut. Slint cannot cfg-gate, so we forward the
                // digit text and the modifier flags; Rust's
                // `parse_sidebar_shortcut` then locks the match to the
                // platform accelerator.
                if (root.ctrl-held || root.meta-held)
                   && (event.text == "1" || event.text == "2"
                       || event.text == "3" || event.text == "4"
                       || event.text == "5" || event.text == "6"
                       || event.text == "7" || event.text == "8"
                       || event.text == "9") {
                    root.sidebar-shortcut(event.text);
                    return accept;
                }
            }
            // Escape: dismiss open dialogs/menus (priority order)
            if event.text == Key.Escape {
                if root.show-command-palette {
                    root.show-command-palette = false;
                    root.palette-dismissed();
                    return accept;
                }
                if root.show-preferences-dialog {
                    root.preferences-cancel-requested();
                    return accept;
                }
                if root.show-context-menu {
                    root.show-context-menu = false;
                    return accept;
                }
                if root.show-delete-dialog {
                    root.show-delete-dialog = false;
                    return accept;
                }
                if root.show-add-magnet-dialog {
                    root.show-add-magnet-dialog = false;
                    return accept;
                }
                if root.show-add-torrent-dialog {
                    root.show-add-torrent-dialog = false;
                    return accept;
                }
            }
            // Modifier tracking
            if event.text == Key.Shift {
                root.shift-held = true;
            }
            if event.text == Key.Control {
                root.ctrl-held = true;
            }
            if event.text == Key.Meta {
                root.meta-held = true;
            }
            accept
        }
        key-released(event) => {
            if event.text == Key.Shift {
                root.shift-held = false;
            }
            if event.text == Key.Control {
                root.ctrl-held = false;
            }
            if event.text == Key.Meta {
                root.meta-held = false;
            }
            accept
        }

        VerticalLayout {
            // Menu bar at top
            menu := MenuBar {
                menu-file-action(index) => {
                    root.menu-file-action(index);
                }
            }

            // ── L1 (3-pane) layout ─────────────────────────────────────
            //
            // Sidebar | (torrent list / detail pane) — the only layout.
            // M173 sidebar gate (`session-ready && error-text == ""`)
            // owned ONCE.
            HorizontalLayout {
                spacing: 0;
                vertical-stretch: 1;

                if root.session-ready && root.error-text == "":
                Sidebar {
                    library-rows: root.sidebar-library-rows;
                    category-rows: root.sidebar-category-rows;
                    tag-rows: root.sidebar-tag-rows;
                    tracker-rows: root.sidebar-tracker-rows;
                    library-collapsed <=> root.sidebar-library-collapsed;
                    category-collapsed <=> root.sidebar-category-collapsed;
                    tag-collapsed <=> root.sidebar-tag-collapsed;
                    tracker-collapsed <=> root.sidebar-tracker-collapsed;
                    mode: "full";
                    predicate-changed(token) => {
                        root.sidebar-predicate-changed(token);
                    }
                    section-toggled(kind, collapsed) => {
                        root.sidebar-section-toggled(kind, collapsed);
                    }
                }

                // List above + detail pane below.
                VerticalLayout {
                    spacing: 0;
                    horizontal-stretch: 1;

                    TorrentListView {
                        vertical-stretch: 2;
                        session-ready: root.session-ready;
                        error-text: root.error-text;
                        torrent-model: root.torrent-model;
                        sort-column: root.sort-column;
                        sort-ascending: root.sort-ascending;
                        col-name-width: root.col-name-width;
                        col-progress-width: root.col-progress-width;
                        col-state-width: root.col-state-width;
                        col-down-rate-width: root.col-down-rate-width;
                        col-up-rate-width: root.col-up-rate-width;
                        col-seeds-width: root.col-seeds-width;
                        col-peers-width: root.col-peers-width;
                        col-eta-width: root.col-eta-width;
                        col-size-width: root.col-size-width;
                        col-ratio-width: root.col-ratio-width;
                        shift-held: root.shift-held;
                        ctrl-held: root.ctrl-held;
                        sort-requested(c) => { root.sort-requested(c); }
                        row-clicked(h, s, c) => { root.row-clicked(h, s, c); }
                        row-right-clicked(h, x, y) => { root.row-right-clicked(h, x, y); }
                    }

                    if root.session-ready && root.error-text == "": Rectangle {
                        vertical-stretch: 1;
                        min-height: Tokens.sp-10 * 5;
                        background: Tokens.bg-1;

                        Rectangle {
                            y: 0;
                            width: parent.width;
                            height: Tokens.border-width-thin;
                            background: Tokens.border-1;
                        }

                        // M177: L1 inline detail pane.
                        DetailPane {
                            y: Tokens.border-width-thin;
                            width: parent.width;
                            height: parent.height - Tokens.border-width-thin;
                            info-hash: root.detail-info-hash;
                            active-tab: root.detail-active-tab;
                            name: root.detail-name;
                            error: root.detail-error;
                            state-label: root.detail-state-label;
                            down-rate: root.detail-down-rate;
                            up-rate: root.detail-up-rate;
                            all-time-down: root.detail-all-time-down;
                            all-time-up: root.detail-all-time-up;
                            ratio: root.detail-ratio;
                            eta: root.detail-eta;
                            num-peers: root.detail-num-peers;
                            num-seeds: root.detail-num-seeds;
                            share-fraction: root.detail-share-fraction;
                            save-path: root.detail-save-path;
                            total-size: root.detail-total-size;
                            piece-count-text: root.detail-piece-count-text;
                            piece-size: root.detail-piece-size;
                            added-time: root.detail-added-time;
                            last-seen-complete: root.detail-last-seen-complete;
                            active-duration: root.detail-active-duration;
                            piece-buckets: root.detail-piece-buckets;
                            pieces-text: root.detail-pieces-text;
                            sequential: root.detail-sequential;
                            files: root.detail-files;
                            peers: root.detail-peers;
                            trackers: root.detail-trackers;
                            http-sources: root.detail-http-sources;
                            speed-dl-path: root.detail-speed-dl-path;
                            speed-ul-path: root.detail-speed-ul-path;
                            speed-max-rate: root.detail-speed-max-rate;
                            speed-current-dl: root.detail-speed-current-dl;
                            speed-current-ul: root.detail-speed-current-ul;
                            speed-dl-limit: root.detail-speed-dl-limit;
                            speed-ul-limit: root.detail-speed-ul-limit;
                            speed-elapsed: root.detail-speed-elapsed;
                            tab-changed(t) => {
                                root.detail-active-tab = t;
                                root.detail-tab-changed(t);
                            }
                            folder-toggled(i) => { root.detail-folder-toggled(i); }
                            sequential-toggled(b) => { root.detail-sequential-toggled(b); }
                            file-clicked(i, c, s) => { root.detail-file-clicked(i, c, s); }
                            file-right-clicked(i, x, y) => { root.detail-file-right-clicked(i, x, y); }
                            folder-right-clicked(k, x, y) => { root.detail-folder-right-clicked(k, x, y); }
                            reannounce-clicked(u) => { root.detail-reannounce(u); }
                                                        speed-dl-limit-applied(v) => { root.detail-speed-dl-limit-applied(v); }
                            speed-ul-limit-applied(v) => { root.detail-speed-ul-limit-applied(v); }
                        }
                    }
                }

            }

            // Status bar at bottom (visible when session ready)
            if root.session-ready: StatusBar {
                down-rate: root.status-down-rate;
                up-rate: root.status-up-rate;
                total-torrents: root.status-total-torrents;
                dht-nodes: root.status-dht-nodes;
                listen-port: root.status-listen-port;
            }
        }
    }

    // Toast overlay at bottom
    if root.toast-visible: Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - Tokens.sp-10 - Tokens.sp-7;
        width: Tokens.sp-10 * 10;
        height: Tokens.chrome-h;
        border-radius: Tokens.r-md;
        background: root.toast-is-error ? Tokens.status-error : Tokens.bg-2;
        border-color: root.toast-is-error ? Tokens.status-error : Tokens.border-1;
        border-width: Tokens.border-width-thin;

        Text {
            text: root.toast-text;
            color: Tokens.fg-0;
            font-size: Tokens.fs-13;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Add Magnet Dialog overlay
    AddMagnetDialog {
        show: root.show-add-magnet-dialog;
        default-dir: root.default-download-dir;
        width: root.width;
        height: root.height;
        add-confirmed(uri, dir) => {
            root.show-add-magnet-dialog = false;
            root.add-magnet-confirmed(uri, dir);
        }
        cancel => {
            root.show-add-magnet-dialog = false;
        }
        browse-download-dir => {
            root.browse-magnet-download-dir();
        }
    }

    // Add Torrent File Dialog overlay
    AddTorrentDialog {
        show: root.show-add-torrent-dialog;
        default-dir: root.default-download-dir;
        torrent-name: root.add-torrent-name;
        torrent-size: root.add-torrent-size;
        torrent-file-count: root.add-torrent-file-count;
        selected-file-path: root.add-torrent-file-path;
        width: root.width;
        height: root.height;
        add-confirmed(path, dir) => {
            root.show-add-torrent-dialog = false;
            root.add-torrent-confirmed(path, dir);
        }
        cancel => {
            root.show-add-torrent-dialog = false;
            root.add-torrent-file-path = "";
            root.add-torrent-name = "";
            root.add-torrent-size = "";
            root.add-torrent-file-count = 0;
        }
        browse-torrent-file => { root.browse-torrent-file(); }
        browse-download-dir => { root.browse-torrent-download-dir(); }
    }

    // Context Menu overlay (on top of everything)
    ContextMenu {
        show: root.show-context-menu;
        menu-x: root.context-menu-x;
        menu-y: root.context-menu-y;
        can-pause: root.ctx-can-pause;
        can-resume: root.ctx-can-resume;
        can-seed-only: root.ctx-can-seed-only;
        can-resume-download: root.ctx-can-resume-download;
        can-recheck: root.ctx-can-recheck;
        width: root.width;
        height: root.height;
        context-action(index) => {
            root.show-context-menu = false;
            root.context-action(index);
        }
        dismiss => {
            root.show-context-menu = false;
        }
    }

    // Delete Confirmation Dialog overlay (on top of context menu)
    ConfirmDeleteDialog {
        show: root.show-delete-dialog;
        count: root.delete-dialog-count;
        delete-files: root.delete-dialog-delete-files;
        width: root.width;
        height: root.height;
        delete-confirmed(delete-files) => {
            root.show-delete-dialog = false;
            root.delete-confirmed(delete-files);
        }
        cancel => {
            root.show-delete-dialog = false;
        }
    }

    // ─────── Overlay z-order (LOAD-BEARING) ──────────
    //
    // Slint renders later children on top, so the order at the root
    // level of MainWindow is itself the z-order from back to front.
    // The required order here is:
    //
    //   1. AddMagnetDialog
    //   2. AddTorrentDialog
    //   3. ContextMenu
    //   4. ConfirmDeleteDialog
    //   5. FilePriorityPopup (M178)
    //   6. CommandPalette (M183)
    //   7. PreferencesDialog (M184)  <-- MUST be the very last child.
    // ──────────────────────────────────────────────────────────

    // M178: File-priority popup (custom-overlay pattern, M164 precedent).
    FilePriorityPopup {
        show: root.show-file-priority-popup;
        popup-x: root.file-priority-popup-x;
        popup-y: root.file-priority-popup-y;
        width: root.width;
        height: root.height;
        priority-selected(p) => {
            root.show-file-priority-popup = false;
            root.file-priority-selected(p);
        }
        dismiss => {
            root.show-file-priority-popup = false;
            root.file-priority-dismissed();
        }
    }

    // M183: Command palette (Ctrl+K / Cmd+K).
    CommandPalette {
        show: root.show-command-palette;
        categories: root.palette-categories;
        active-index: root.palette-active-index;
        total-count: root.palette-total-count;
        width: root.width;
        height: root.height;
        query-changed(q) => { root.palette-query-changed(q); }
        item-selected(i) => { root.palette-item-selected(i); }
        dismiss => {
            root.show-command-palette = false;
            root.palette-dismissed();
        }
    }

    // M184: Preferences dialog — MUST stay LAST child of MainWindow
    // per the z-order spec (replaces TweaksOverlay slot 8).
    PreferencesDialog {
        show: root.show-preferences-dialog;
        active-tab: "behavior";
        dirty <=> root.pref-dirty;
        width: root.width;
        height: root.height;
        pref-skin <=> root.pref-skin;
        pref-theme <=> root.pref-theme;
        pref-density <=> root.pref-density;
        pref-radius <=> root.pref-radius;
        pref-confirm-delete <=> root.pref-confirm-delete;
        pref-confirm-pause-all <=> root.pref-confirm-pause-all;
        pref-show-torrent-added-toast <=> root.pref-show-torrent-added-toast;
        pref-double-click-action <=> root.pref-double-click-action;
        pref-start-minimized <=> root.pref-start-minimized;
        pref-minimize-to-tray <=> root.pref-minimize-to-tray;
        pref-resume-previous-session <=> root.pref-resume-previous-session;
        pref-notify-on-complete <=> root.pref-notify-on-complete;
        pref-notify-on-error <=> root.pref-notify-on-error;
        pref-notify-on-rss <=> root.pref-notify-on-rss;
        pref-play-sound-on-complete <=> root.pref-play-sound-on-complete;
        pref-on-complete-program <=> root.pref-on-complete-program;
        pref-download-dir <=> root.pref-download-dir;
        pref-use-incomplete-dir <=> root.pref-use-incomplete-dir;
        pref-incomplete-dir <=> root.pref-incomplete-dir;
        pref-create-subfolder <=> root.pref-create-subfolder;
        pref-pre-allocate <=> root.pref-pre-allocate;
        pref-show-add-torrent-dialog <=> root.pref-show-add-torrent-dialog;
        pref-skip-hash-check <=> root.pref-skip-hash-check;
        pref-incomplete-extension <=> root.pref-incomplete-extension;
        pref-use-auto-categories <=> root.pref-use-auto-categories;
        pref-append-date-to-path <=> root.pref-append-date-to-path;
        pref-watched-folder <=> root.pref-watched-folder;
        pref-copy-torrent-to <=> root.pref-copy-torrent-to;
        pref-delete-torrent-after-add <=> root.pref-delete-torrent-after-add;
        pref-move-completed-enabled <=> root.pref-move-completed-enabled;
        pref-move-completed-to <=> root.pref-move-completed-to;
        pref-dl-on-complete-program <=> root.pref-dl-on-complete-program;
        // M185 Connection
        pref-listen-port <=> root.pref-listen-port;
        pref-randomize-port <=> root.pref-randomize-port;
        pref-enable-upnp <=> root.pref-enable-upnp;
        pref-enable-natpmp <=> root.pref-enable-natpmp;
        pref-max-connections-global <=> root.pref-max-connections-global;
        pref-max-peers-per-torrent <=> root.pref-max-peers-per-torrent;
        pref-max-upload-slots-global <=> root.pref-max-upload-slots-global;
        pref-max-upload-slots-per-torrent <=> root.pref-max-upload-slots-per-torrent;
        pref-active-downloads <=> root.pref-active-downloads;
        pref-active-seeds <=> root.pref-active-seeds;
        pref-active-limit <=> root.pref-active-limit;
        pref-proxy-type <=> root.pref-proxy-type;
        pref-proxy-host <=> root.pref-proxy-host;
        pref-proxy-port <=> root.pref-proxy-port;
        pref-proxy-peer-connections <=> root.pref-proxy-peer-connections;
        pref-proxy-hostnames <=> root.pref-proxy-hostnames;
        pref-ip-filter-enabled <=> root.pref-ip-filter-enabled;
        pref-ip-filter-path <=> root.pref-ip-filter-path;
        pref-ip-filter-auto-refresh <=> root.pref-ip-filter-auto-refresh;
        // M185 Speed
        pref-dl-limit-enabled <=> root.pref-dl-limit-enabled;
        pref-dl-limit-value <=> root.pref-dl-limit-value;
        pref-ul-limit-enabled <=> root.pref-ul-limit-enabled;
        pref-ul-limit-value <=> root.pref-ul-limit-value;
        pref-alt-dl-limit <=> root.pref-alt-dl-limit;
        pref-alt-ul-limit <=> root.pref-alt-ul-limit;
        pref-alt-speed-enabled <=> root.pref-alt-speed-enabled;
        pref-rate-limit-overhead <=> root.pref-rate-limit-overhead;
        pref-rate-limit-utp <=> root.pref-rate-limit-utp;
        pref-rate-limit-lan <=> root.pref-rate-limit-lan;
        // M187: BitTorrent
        pref-enable-dht <=> root.pref-enable-dht;
        pref-enable-pex <=> root.pref-enable-pex;
        pref-enable-lsd <=> root.pref-enable-lsd;
        pref-encryption-mode <=> root.pref-encryption-mode;
        pref-anonymous-mode <=> root.pref-anonymous-mode;
        pref-seed-ratio-enabled <=> root.pref-seed-ratio-enabled;
        pref-seed-ratio-value <=> root.pref-seed-ratio-value;
        pref-max-ratio-action <=> root.pref-max-ratio-action;
        pref-seed-time-enabled <=> root.pref-seed-time-enabled;
        pref-seed-time-value <=> root.pref-seed-time-value;
        pref-inactive-seed-time-enabled <=> root.pref-inactive-seed-time-enabled;
        pref-inactive-seed-time-value <=> root.pref-inactive-seed-time-value;
        pref-queueing-enabled <=> root.pref-queueing-enabled;
        // M187: RSS
        pref-rss-enabled <=> root.pref-rss-enabled;
        pref-rss-refresh-interval <=> root.pref-rss-refresh-interval;
        pref-rss-max-articles <=> root.pref-rss-max-articles;
        pref-rss-auto-download <=> root.pref-rss-auto-download;
        pref-rss-smart-filter <=> root.pref-rss-smart-filter;
        pref-rss-download-repacks <=> root.pref-rss-download-repacks;
        // M187: Web UI
        pref-webui-enabled <=> root.pref-webui-enabled;
        pref-webui-bind <=> root.pref-webui-bind;
        pref-webui-port <=> root.pref-webui-port;
        pref-webui-https <=> root.pref-webui-https;
        pref-webui-username <=> root.pref-webui-username;
        pref-webui-bypass-local-auth <=> root.pref-webui-bypass-local-auth;
        pref-webui-session-ttl <=> root.pref-webui-session-ttl;
        pref-webui-max-failed-auth <=> root.pref-webui-max-failed-auth;
        pref-webui-ban-duration <=> root.pref-webui-ban-duration;
        pref-webui-csrf <=> root.pref-webui-csrf;
        pref-webui-host-validation <=> root.pref-webui-host-validation;
        pref-webui-reverse-proxy <=> root.pref-webui-reverse-proxy;
        pref-ddns-enabled <=> root.pref-ddns-enabled;
        pref-ddns-service <=> root.pref-ddns-service;
        pref-ddns-domain <=> root.pref-ddns-domain;
        // M187: Advanced
        pref-hashing-threads <=> root.pref-hashing-threads;
        pref-save-resume-interval <=> root.pref-save-resume-interval;
        pref-storage-mode <=> root.pref-storage-mode;
        pref-disk-cache-size <=> root.pref-disk-cache-size;
        pref-enable-utp <=> root.pref-enable-utp;
        pref-enable-fast-ext <=> root.pref-enable-fast-ext;
        pref-enable-holepunch <=> root.pref-enable-holepunch;
        pref-enable-bep40 <=> root.pref-enable-bep40;
        pref-config-path <=> root.pref-config-path;
        apply-requested => { root.preferences-apply-requested(); }
        cancel-requested => { root.preferences-cancel-requested(); }
        ok-requested => { root.preferences-ok-requested(); }
        browse-download-dir => { root.preferences-browse-download-dir(); }
        browse-incomplete-dir => { root.preferences-browse-incomplete-dir(); }
        browse-watched-folder => { root.preferences-browse-watched-folder(); }
        browse-copy-torrent-to => { root.preferences-browse-copy-torrent-to(); }
        browse-move-completed-to => { root.preferences-browse-move-completed-to(); }
    }
}
