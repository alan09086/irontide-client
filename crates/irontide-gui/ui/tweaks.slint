// IronTide Tweaks overlay — in-app skin/theme/density/radius picker.
//
// Toggled via Ctrl+Shift+T (Cmd+Shift+T on macOS). Each click fires a
// per-axis callback that Rust handles by mutating `SkinSettings` and
// calling `apply()` against the live window.

import { Tokens } from "tokens.slint";

// Small row of pill-shaped option buttons with a label on the left.
component PillRow {
    in property <string> label;
    in property <[string]> options;
    in property <string> selected;
    in property <bool> disabled: false;
    callback option-clicked(string);

    HorizontalLayout {
        spacing: Tokens.sp-4;
        alignment: start;

        Text {
            text: root.label;
            color: Tokens.fg-2;
            font-size: Tokens.fs-13;
            width: Tokens.sp-10 * 2;
            vertical-alignment: center;
        }

        for opt[idx] in root.options: Rectangle {
            background: root.selected == opt ? Tokens.accent : Tokens.bg-2;
            border-radius: Tokens.r-md;
            border-width: Tokens.border-width-thin;
            border-color: Tokens.border-1;

            Text {
                x: Tokens.sp-4;
                y: Tokens.sp-2;
                text: opt;
                color: root.selected == opt
                    ? Tokens.accent-fg
                    : (root.disabled ? Tokens.fg-3 : Tokens.fg-1);
                font-size: Tokens.fs-12;
            }

            width: self.preferred-width + Tokens.sp-8;
            height: Tokens.row-h;

            touch := TouchArea {
                enabled: !root.disabled;
                clicked => { root.option-clicked(opt); }
            }
        }
    }
}

export component TweaksOverlay {
    in-out property <bool> show: false;
    in property <string> current-skin: "tide";
    in property <string> current-theme: "dark";
    in property <string> current-density: "balanced";
    in property <string> current-radius: "balanced";

    callback skin-changed(string);
    callback theme-changed(string);
    callback density-changed(string);
    callback radius-changed(string);

    // x/y/width are set by the consumer (main.slint positions the
    // overlay near the top-right corner of MainWindow).
    width: Tokens.sp-10 * 8;
    height: body-layout.preferred-height;

    visible: root.show;

    Rectangle {
        background: Tokens.bg-1;
        border-radius: Tokens.r-lg;
        border-width: Tokens.border-width-thin;
        border-color: Tokens.border-2;
        drop-shadow-color: Tokens.shadow-lg.color;
        drop-shadow-blur: Tokens.shadow-lg.blur;
        drop-shadow-offset-y: Tokens.shadow-lg.offset-y;

        body-layout := VerticalLayout {
            padding: Tokens.sp-5;
            spacing: Tokens.sp-4;

            Text {
                text: "Tweaks";
                color: Tokens.fg-0;
                font-size: Tokens.fs-16;
            }

            PillRow {
                label: "Skin";
                options: ["tide", "forge", "abyss"];
                selected: root.current-skin;
                option-clicked(o) => { root.skin-changed(o); }
            }
            PillRow {
                label: "Theme";
                options: ["dark", "light"];
                selected: root.current-theme;
                option-clicked(o) => { root.theme-changed(o); }
            }
            PillRow {
                label: "Density";
                options: ["compact", "balanced", "spacious"];
                selected: root.current-density;
                option-clicked(o) => { root.density-changed(o); }
            }
            PillRow {
                label: "Radius";
                options: ["sharp", "balanced", "rounded"];
                selected: root.current-radius;
                option-clicked(o) => { root.radius-changed(o); }
            }
            PillRow {
                label: "Layout";
                options: ["compact", "balanced", "spacious"];
                selected: "balanced";
                disabled: true;
            }
        }
    }
}
