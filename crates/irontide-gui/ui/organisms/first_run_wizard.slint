// First-run wizard (M210 → rebuilt M220).
//
// M220 replaces the bespoke Rectangle/TouchArea/TextInput primitives with
// the shared Pref* molecule vocabulary (PrefField, PrefTextInput,
// PrefToggle) so the wizard reads visually identical to the Preferences
// dialog. Adds a Browse… button on step 0 (rfd folder picker) and inline
// validation hints for the download dir and listen port.

import { Tokens } from "../tokens.slint";
import { PrefField, PrefToggle, PrefTextInput } from "../molecules/pref_controls.slint";

export component FirstRunWizard inherits Rectangle {
    accessible-role: none;
    accessible-label: "First run setup wizard";
    in property <int> step: 0;
    in property <string> download-dir: "";
    in property <string> listen-port: "6881";
    in property <bool> enable-dht: true;
    in property <bool> enable-utp: true;
    in property <bool> enable-pex: true;
    // Inline validation hints rendered under the corresponding field.
    // Set by root via the Rust validate-port / validate-dir callbacks.
    in property <string> dir-error: "";
    in property <string> port-error: "";

    callback set-download-dir(string);
    callback set-listen-port(string);
    callback toggle-dht(bool);
    callback toggle-utp(bool);
    callback toggle-pex(bool);
    callback browse-download-dir();
    callback next-step();
    callback prev-step();
    callback finish();

    background: Tokens.bg-0;

    VerticalLayout {
        padding: Tokens.sp-7;
        spacing: Tokens.sp-5;
        alignment: center;

        // Title
        Text {
            text: "Welcome to IronTide";
            font-size: Tokens.fs-24;
            font-weight: 600;
            color: Tokens.fg-0;
            horizontal-alignment: center;
        }

        Text {
            text: "Let's set up a few things before you start.";
            font-size: Tokens.fs-13;
            color: Tokens.fg-2;
            horizontal-alignment: center;
        }

        // Step indicators
        HorizontalLayout {
            alignment: center;
            spacing: Tokens.sp-2;

            for i in [0, 1, 2] : Rectangle {
                width: root.step == i ? 24px : 8px;
                height: 8px;
                border-radius: 4px;
                background: root.step == i ? Tokens.accent : Tokens.bg-2;
            }
        }

        Rectangle { height: Tokens.sp-4; }

        // Step 0: Download directory (M220 — Pref* molecules + Browse).
        if root.step == 0 : VerticalLayout {
            spacing: Tokens.sp-3;
            alignment: center;
            horizontal-stretch: 1;
            max-width: 560px;

            Text {
                text: "Download Directory";
                font-size: Tokens.fs-18;
                font-weight: 600;
                color: Tokens.fg-0;
                horizontal-alignment: center;
            }

            Text {
                text: "Where should downloaded files be saved?";
                font-size: Tokens.fs-12;
                color: Tokens.fg-2;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Rectangle { height: Tokens.sp-2; }

            PrefField {
                label: "Folder";
                hint: "You can change this later in Preferences.";
                HorizontalLayout {
                    spacing: Tokens.sp-4;
                    horizontal-stretch: 1;

                    PrefTextInput {
                        value: root.download-dir;
                        placeholder: "/path/to/downloads";
                        edited(v) => { root.set-download-dir(v); }
                    }

                    Rectangle {
                        width: Tokens.sp-10 * 2;
                        height: Tokens.chrome-h - Tokens.sp-2;
                        background: browse-touch.has-hover ? Tokens.bg-hover : Tokens.accent;
                        border-radius: Tokens.r-md;

                        Text {
                            text: "Browse\u{2026}";
                            color: Tokens.accent-fg;
                            font-size: Tokens.fs-13;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        browse-touch := TouchArea {
                            accessible-role: button;
                            accessible-label: "Browse for download folder";
                            mouse-cursor: pointer;
                            clicked => { root.browse-download-dir(); }
                        }
                    }
                }
            }

            if root.dir-error != "" : Text {
                text: root.dir-error;
                color: #ef4444;
                font-size: 11px;
                horizontal-alignment: center;
            }
        }

        // Step 1: Connection settings (M220 — Pref* molecules).
        if root.step == 1 : VerticalLayout {
            spacing: Tokens.sp-3;
            alignment: center;
            max-width: 560px;
            horizontal-stretch: 1;

            Text {
                text: "Connection Settings";
                font-size: Tokens.fs-18;
                font-weight: 600;
                color: Tokens.fg-0;
                horizontal-alignment: center;
            }

            Text {
                text: "These defaults work well for most users.";
                font-size: Tokens.fs-12;
                color: Tokens.fg-2;
                horizontal-alignment: center;
            }

            Rectangle { height: Tokens.sp-2; }

            VerticalLayout {
                spacing: Tokens.sp-2;
                horizontal-stretch: 1;

                PrefField {
                    label: "Listen Port";
                    hint: "TCP/UDP port BitTorrent peers connect on.";
                    PrefTextInput {
                        value: root.listen-port;
                        placeholder: "1024-65535";
                        edited(v) => { root.set-listen-port(v); }
                    }
                }

                if root.port-error != "" : Text {
                    text: root.port-error;
                    color: #ef4444;
                    font-size: 11px;
                }

                PrefField {
                    label: "DHT (Distributed Hash Table)";
                    PrefToggle {
                        checked: root.enable-dht;
                        toggled(v) => { root.toggle-dht(v); }
                    }
                }

                PrefField {
                    label: "uTP (Micro Transport Protocol)";
                    PrefToggle {
                        checked: root.enable-utp;
                        toggled(v) => { root.toggle-utp(v); }
                    }
                }

                PrefField {
                    label: "PEX (Peer Exchange)";
                    PrefToggle {
                        checked: root.enable-pex;
                        toggled(v) => { root.toggle-pex(v); }
                    }
                }
            }
        }

        // Step 2: Ready (unchanged from M210).
        if root.step == 2 : VerticalLayout {
            spacing: Tokens.sp-3;
            alignment: center;

            Text {
                text: "You're All Set";
                font-size: Tokens.fs-18;
                font-weight: 600;
                color: Tokens.fg-0;
                horizontal-alignment: center;
            }

            Text {
                text: "IronTide is ready to go. You can adjust any setting\nlater from Preferences (Ctrl+,).";
                font-size: Tokens.fs-12;
                color: Tokens.fg-2;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Text {
                text: "Tip: Press Ctrl+K to open the command palette.";
                font-size: Tokens.fs-11;
                color: Tokens.fg-2;
                horizontal-alignment: center;
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Navigation buttons
        HorizontalLayout {
            alignment: center;
            spacing: Tokens.sp-3;

            if root.step > 0 : TouchArea {
                width: 100px;
                height: 36px;
                mouse-cursor: pointer;
                clicked => { root.prev-step(); }

                back-btn := Rectangle {
                    background: back-ta.has-hover ? Tokens.bg-2 : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    back-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.prev-step(); }
                    }

                    Text {
                        text: "Back";
                        font-size: Tokens.fs-12;
                        color: Tokens.fg-1;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            TouchArea {
                width: 140px;
                height: 36px;
                mouse-cursor: pointer;
                clicked => {
                    if root.step < 2 {
                        root.next-step();
                    } else {
                        root.finish();
                    }
                }

                next-btn := Rectangle {
                    background: next-ta.has-hover ? #3b82f6 : Tokens.accent;
                    border-radius: Tokens.r-sm;

                    next-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if root.step < 2 {
                                root.next-step();
                            } else {
                                root.finish();
                            }
                        }
                    }

                    Text {
                        text: root.step < 2 ? "Next" : "Get Started";
                        font-size: Tokens.fs-12;
                        color: white;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
