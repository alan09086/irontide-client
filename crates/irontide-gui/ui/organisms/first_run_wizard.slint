import { Tokens } from "../tokens.slint";

export component FirstRunWizard inherits Rectangle {
    in property <int> step: 0;
    in property <string> download-dir: "";
    in property <string> listen-port: "6881";
    in property <bool> enable-dht: true;
    in property <bool> enable-utp: true;
    in property <bool> enable-pex: true;

    callback set-download-dir(string);
    callback set-listen-port(string);
    callback toggle-dht(bool);
    callback toggle-utp(bool);
    callback toggle-pex(bool);
    callback next-step();
    callback prev-step();
    callback finish();

    background: Tokens.bg-0;

    VerticalLayout {
        padding: Tokens.sp-7;
        spacing: Tokens.sp-5;
        alignment: center;

        // Title
        Text {
            text: "Welcome to IronTide";
            font-size: Tokens.fs-24;
            font-weight: 600;
            color: Tokens.fg-0;
            horizontal-alignment: center;
        }

        Text {
            text: "Let's set up a few things before you start.";
            font-size: Tokens.fs-13;
            color: Tokens.fg-2;
            horizontal-alignment: center;
        }

        // Step indicators
        HorizontalLayout {
            alignment: center;
            spacing: Tokens.sp-2;

            for i in [0, 1, 2] : Rectangle {
                width: root.step == i ? 24px : 8px;
                height: 8px;
                border-radius: 4px;
                background: root.step == i ? Tokens.accent : Tokens.bg-2;
            }
        }

        Rectangle { height: Tokens.sp-4; }

        // Step 0: Download directory
        if root.step == 0 : VerticalLayout {
            spacing: Tokens.sp-3;
            alignment: center;
            horizontal-stretch: 1;

            Text {
                text: "Download Directory";
                font-size: Tokens.fs-18;
                font-weight: 600;
                color: Tokens.fg-0;
                horizontal-alignment: center;
            }

            Text {
                text: "Where should downloaded files be saved?";
                font-size: Tokens.fs-12;
                color: Tokens.fg-2;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Rectangle {
                background: Tokens.bg-1;
                border-radius: Tokens.r-sm;
                height: 40px;
                max-width: 480px;

                HorizontalLayout {
                    padding-left: Tokens.sp-3;
                    padding-right: Tokens.sp-3;

                    dir-input := TextInput {
                        text: root.download-dir;
                        font-size: Tokens.fs-13;
                        color: Tokens.fg-0;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        edited => { root.set-download-dir(self.text); }
                    }
                }
            }

            Text {
                text: "You can change this later in Preferences.";
                font-size: Tokens.fs-10;
                color: Tokens.fg-2;
                horizontal-alignment: center;
            }
        }

        // Step 1: Connection settings
        if root.step == 1 : VerticalLayout {
            spacing: Tokens.sp-3;
            alignment: center;

            Text {
                text: "Connection Settings";
                font-size: Tokens.fs-18;
                font-weight: 600;
                color: Tokens.fg-0;
                horizontal-alignment: center;
            }

            Text {
                text: "These defaults work well for most users.";
                font-size: Tokens.fs-12;
                color: Tokens.fg-2;
                horizontal-alignment: center;
            }

            VerticalLayout {
                spacing: Tokens.sp-2;
                max-width: 400px;

                HorizontalLayout {
                    spacing: Tokens.sp-3;

                    Text {
                        text: "Listen Port";
                        font-size: Tokens.fs-12;
                        color: Tokens.fg-1;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Rectangle {
                        background: Tokens.bg-1;
                        border-radius: Tokens.r-sm;
                        width: 80px;
                        height: 32px;

                        port-input := TextInput {
                            text: root.listen-port;
                            font-size: Tokens.fs-12;
                            color: Tokens.fg-0;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            edited => { root.set-listen-port(self.text); }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: Tokens.sp-3;
                    Text {
                        text: "DHT (Distributed Hash Table)";
                        font-size: Tokens.fs-12;
                        color: Tokens.fg-1;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: root.enable-dht ? "On" : "Off";
                        font-size: Tokens.fs-12;
                        color: root.enable-dht ? Tokens.accent : Tokens.fg-2;
                        vertical-alignment: center;
                    }
                    dht-ta := TouchArea {
                        width: 40px;
                        mouse-cursor: pointer;
                        clicked => { root.toggle-dht(!root.enable-dht); }
                        Rectangle {
                            background: root.enable-dht ? Tokens.accent : Tokens.bg-2;
                            border-radius: 10px;
                            width: 40px;
                            height: 20px;
                            Rectangle {
                                x: root.enable-dht ? 22px : 2px;
                                y: 2px;
                                width: 16px;
                                height: 16px;
                                border-radius: 8px;
                                background: white;
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: Tokens.sp-3;
                    Text {
                        text: "uTP (Micro Transport Protocol)";
                        font-size: Tokens.fs-12;
                        color: Tokens.fg-1;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: root.enable-utp ? "On" : "Off";
                        font-size: Tokens.fs-12;
                        color: root.enable-utp ? Tokens.accent : Tokens.fg-2;
                        vertical-alignment: center;
                    }
                    utp-ta := TouchArea {
                        width: 40px;
                        mouse-cursor: pointer;
                        clicked => { root.toggle-utp(!root.enable-utp); }
                        Rectangle {
                            background: root.enable-utp ? Tokens.accent : Tokens.bg-2;
                            border-radius: 10px;
                            width: 40px;
                            height: 20px;
                            Rectangle {
                                x: root.enable-utp ? 22px : 2px;
                                y: 2px;
                                width: 16px;
                                height: 16px;
                                border-radius: 8px;
                                background: white;
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: Tokens.sp-3;
                    Text {
                        text: "PEX (Peer Exchange)";
                        font-size: Tokens.fs-12;
                        color: Tokens.fg-1;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: root.enable-pex ? "On" : "Off";
                        font-size: Tokens.fs-12;
                        color: root.enable-pex ? Tokens.accent : Tokens.fg-2;
                        vertical-alignment: center;
                    }
                    pex-ta := TouchArea {
                        width: 40px;
                        mouse-cursor: pointer;
                        clicked => { root.toggle-pex(!root.enable-pex); }
                        Rectangle {
                            background: root.enable-pex ? Tokens.accent : Tokens.bg-2;
                            border-radius: 10px;
                            width: 40px;
                            height: 20px;
                            Rectangle {
                                x: root.enable-pex ? 22px : 2px;
                                y: 2px;
                                width: 16px;
                                height: 16px;
                                border-radius: 8px;
                                background: white;
                            }
                        }
                    }
                }
            }
        }

        // Step 2: Ready
        if root.step == 2 : VerticalLayout {
            spacing: Tokens.sp-3;
            alignment: center;

            Text {
                text: "You're All Set";
                font-size: Tokens.fs-18;
                font-weight: 600;
                color: Tokens.fg-0;
                horizontal-alignment: center;
            }

            Text {
                text: "IronTide is ready to go. You can adjust any setting\nlater from Preferences (Ctrl+,).";
                font-size: Tokens.fs-12;
                color: Tokens.fg-2;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Text {
                text: "Tip: Press Ctrl+K to open the command palette.";
                font-size: Tokens.fs-11;
                color: Tokens.fg-2;
                horizontal-alignment: center;
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Navigation buttons
        HorizontalLayout {
            alignment: center;
            spacing: Tokens.sp-3;

            if root.step > 0 : TouchArea {
                width: 100px;
                height: 36px;
                mouse-cursor: pointer;
                clicked => { root.prev-step(); }

                back-btn := Rectangle {
                    background: back-ta.has-hover ? Tokens.bg-2 : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    back-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.prev-step(); }
                    }

                    Text {
                        text: "Back";
                        font-size: Tokens.fs-12;
                        color: Tokens.fg-1;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            TouchArea {
                width: 140px;
                height: 36px;
                mouse-cursor: pointer;
                clicked => {
                    if root.step < 2 {
                        root.next-step();
                    } else {
                        root.finish();
                    }
                }

                next-btn := Rectangle {
                    background: next-ta.has-hover ? #3b82f6 : Tokens.accent;
                    border-radius: Tokens.r-sm;

                    next-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if root.step < 2 {
                                root.next-step();
                            } else {
                                root.finish();
                            }
                        }
                    }

                    Text {
                        text: root.step < 2 ? "Next" : "Get Started";
                        font-size: Tokens.fs-12;
                        color: white;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
