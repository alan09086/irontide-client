                                                toggled(v) => {
                                                    root.pref-rss-download-repacks = v;
                                                    root.dirty = true;
                                                }
                                            }
                                            Text {
                                                text: "v1.x — see M239";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-12;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefResetRow {
                                        reset-requested => { root.reset-tab("rss"); }
                                    }
                                }

                                // ── Web UI tab ───────────────────────
                                if root.active-tab == "webui": VerticalLayout {
                                    spacing: Tokens.sp-4;

                                    PrefGroup { title: "WEB USER INTERFACE"; }

                                    PrefField {
                                        label: "Enable";
                                        PrefToggle {
                                            checked: root.pref-webui-enabled;
                                            toggled(v) => {
                                                root.pref-webui-enabled = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Bind address";
                                        hint: "Restart required for changes to take effect";
                                        PrefTextInput {
                                            value: root.pref-webui-bind;
                                            placeholder: "127.0.0.1";
                                            input-enabled: true;
                                            edited(v) => {
                                                root.pref-webui-bind = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Port";
                                        hint: "Restart required for changes to take effect";
                                        PrefTextInput {
                                            value: root.pref-webui-port;
                                            placeholder: "9080";
                                            input-enabled: true;
                                            edited(v) => {
                                                root.pref-webui-port = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Use HTTPS";
                                        not-yet-active: true;
                                        HorizontalLayout {
                                            spacing: Tokens.sp-2;
                                            PrefToggle {
                                                checked: root.pref-webui-https;
                                                toggle-enabled: false;
                                                toggled(v) => {
                                                    root.pref-webui-https = v;
                                                    root.dirty = true;
                                                }
                                            }
                                            Text {
                                                text: "v1.x — M232";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-12;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefGroup { title: "AUTHENTICATION"; }

                                    PrefField {
                                        label: "Username";
                                        PrefTextInput {
                                            value: root.pref-webui-username;
                                            placeholder: "admin";
                                            edited(v) => {
                                                root.pref-webui-username = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Password";
                                        not-yet-active: true;
                                        HorizontalLayout {
                                            spacing: Tokens.sp-2;
                                            Text {
                                                text: "Change via config file (argon2 hashed)";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-13;
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: "v1.x — M232";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-12;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Bypass auth on localhost";
                                        PrefToggle {
                                            checked: root.pref-webui-bypass-local-auth;
                                            toggled(v) => {
                                                root.pref-webui-bypass-local-auth = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Session timeout";
                                        HorizontalLayout {
                                            spacing: Tokens.sp-4;
                                            PrefTextInput {
                                                value: root.pref-webui-session-ttl;
                                                placeholder: "86400";
                                                edited(v) => {
                                                    root.pref-webui-session-ttl = v;
                                                    root.dirty = true;
                                                }
                                            }
                                            Text {
                                                text: "sec";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-13;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Max login attempts";
                                        PrefTextInput {
                                            value: root.pref-webui-max-failed-auth;
                                            placeholder: "5";
                                            edited(v) => {
                                                root.pref-webui-max-failed-auth = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Ban duration";
                                        HorizontalLayout {
                                            spacing: Tokens.sp-4;
                                            PrefTextInput {
                                                value: root.pref-webui-ban-duration;
                                                placeholder: "3600";
                                                edited(v) => {
                                                    root.pref-webui-ban-duration = v;
                                                    root.dirty = true;
                                                }
                                            }
                                            Text {
                                                text: "sec";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-13;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefGroup { title: "SECURITY"; }

                                    PrefField {
                                        label: "CSRF protection";
                                        PrefToggle {
                                            checked: root.pref-webui-csrf;
                                            toggled(v) => {
                                                root.pref-webui-csrf = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Host header validation";
                                        PrefToggle {
                                            checked: root.pref-webui-host-validation;
                                            toggled(v) => {
                                                root.pref-webui-host-validation = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Reverse proxy support";
                                        PrefToggle {
                                            checked: root.pref-webui-reverse-proxy;
                                            toggled(v) => {
                                                root.pref-webui-reverse-proxy = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefGroup { title: "DYNAMIC DNS"; }

                                    PrefField {
                                        label: "Enable";
                                        not-yet-active: true;
                                        HorizontalLayout {
                                            spacing: Tokens.sp-2;
                                            PrefToggle {
                                                checked: root.pref-ddns-enabled;
                                                toggle-enabled: false;
                                                toggled(v) => {
                                                    root.pref-ddns-enabled = v;
                                                    root.dirty = true;
                                                }
                                            }
                                            Text {
                                                text: "v1.x — coming";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-12;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Service";
                                        not-yet-active: true;
                                        field-enabled: root.pref-ddns-enabled;
                                        HorizontalLayout {
                                            spacing: Tokens.sp-2;
                                            PrefSelect {
                                                current-value: root.pref-ddns-service == "" ? "dyndns.org" : root.pref-ddns-service;
                                                options: ["dyndns.org", "no-ip.com", "duckdns.org", "cloudflare"];
                                                select-id: "ddns";
                                                popup-open: root.popup-visible && root.popup-id == "ddns";
                                                select-enabled: false;
                                                value-changed(v) => {
                                                    root.pref-ddns-service = v;
                                                    root.dirty = true;
                                                }
                                                request-popup(id, x, y, w) => {
                                                    root.show-select-popup(id, x, y, w, self.options, self.current-value);
                                                }
                                            }
                                            Text {
                                                text: "v1.x — coming";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-12;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Domain";
                                        not-yet-active: true;
                                        field-enabled: root.pref-ddns-enabled;
                                        HorizontalLayout {
                                            spacing: Tokens.sp-2;
                                            PrefTextInput {
                                                value: root.pref-ddns-domain;
                                                placeholder: "my-seed.duckdns.org";
                                                input-enabled: false;
                                                edited(v) => {
                                                    root.pref-ddns-domain = v;
                                                    root.dirty = true;
                                                }
                                            }
                                            Text {
                                                text: "v1.x — coming";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-12;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefResetRow {
                                        reset-requested => { root.reset-tab("webui"); }
                                    }
                                }

                                // ── Advanced tab ─────────────────────
                                if root.active-tab == "advanced": VerticalLayout {
                                    spacing: Tokens.sp-4;

                                    PrefGroup { title: "TUNING"; }

                                    PrefField {
                                        label: "Hashing threads";
                                        PrefTextInput {
                                            value: root.pref-hashing-threads;
                                            placeholder: "4";
                                            edited(v) => {
                                                root.pref-hashing-threads = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Save resume data interval";
                                        HorizontalLayout {
                                            spacing: Tokens.sp-4;
                                            PrefTextInput {
                                                value: root.pref-save-resume-interval;
                                                placeholder: "5";
                                                edited(v) => {
                                                    root.pref-save-resume-interval = v;
                                                    root.dirty = true;
                                                }
                                            }
                                            Text {
                                                text: "min";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-13;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "Disk I/O backend";
                                        Text {
                                            text: root.pref-storage-mode;
                                            color: Tokens.fg-3;
                                            font-size: Tokens.fs-13;
                                            vertical-alignment: center;
                                        }
                                    }

                                    PrefField {
                                        label: "Disk cache size";
                                        HorizontalLayout {
                                            spacing: Tokens.sp-4;
                                            PrefTextInput {
                                                value: root.pref-disk-cache-size;
                                                placeholder: "-1";
                                                edited(v) => {
                                                    root.pref-disk-cache-size = v;
                                                    root.dirty = true;
                                                }
                                            }
                                            Text {
                                                text: "MiB (-1 = auto)";
                                                color: Tokens.fg-3;
                                                font-size: Tokens.fs-13;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    PrefGroup { title: "NETWORK"; }

                                    PrefField {
                                        label: "Network interface";
                                        PrefTextInput {
                                            value: root.pref-network-interface;
                                            placeholder: "Any (leave blank)";
                                            edited(v) => {
                                                root.pref-network-interface = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefGroup { title: "BEHAVIOUR"; }

                                    PrefField {
                                        label: "\u{00b5}TP enabled";
                                        PrefToggle {
                                            checked: root.pref-enable-utp;
                                            toggled(v) => {
                                                root.pref-enable-utp = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "BEP 6 Fast Extension";
                                        PrefToggle {
                                            checked: root.pref-enable-fast-ext;
                                            toggled(v) => {
                                                root.pref-enable-fast-ext = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "BEP 55 Holepunch";
                                        PrefToggle {
                                            checked: root.pref-enable-holepunch;
                                            toggled(v) => {
                                                root.pref-enable-holepunch = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefField {
                                        label: "BEP 40 Peer Priority";
                                        PrefToggle {
                                            checked: root.pref-enable-bep40;
                                            toggled(v) => {
                                                root.pref-enable-bep40 = v;
                                                root.dirty = true;
                                            }
                                        }
                                    }

                                    PrefGroup { title: "CONFIGURATION"; }

                                    PrefField {
                                        label: "Config file";
                                        not-yet-active: true;
                                        Text {
                                            text: root.pref-config-path;
                                            color: Tokens.fg-2;
                                            font-size: Tokens.fs-13;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }

                                    PrefResetRow {
                                        reset-requested => { root.reset-tab("advanced"); }
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Footer ────────────────────────────────────────────
                Rectangle {
                    height: Tokens.chrome-h + Tokens.sp-6;
                    background: Tokens.bg-1;

                    Rectangle {
                        y: 0;
                        width: parent.width;
                        height: Tokens.border-width-thin;
                        background: Tokens.border-1;
                    }

                    HorizontalLayout {
                        alignment: end;
                        padding-right: Tokens.sp-6;
                        spacing: Tokens.sp-4;

                        // Cancel (ghost style)
                        Rectangle {
                            width: Tokens.sp-10 * 2;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: cancel-btn-touch.has-hover ? Tokens.bg-hover : transparent;
                            border-color: Tokens.border-1;
                            border-width: Tokens.border-width-thin;
                            border-radius: Tokens.r-md;

                            Text {
                                text: "Cancel";
                                color: Tokens.fg-1;
                                font-size: Tokens.fs-13;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            cancel-btn-touch := TouchArea {
                                clicked => { root.cancel-requested(); }
                            }
                        }

                        // Apply (disabled when not dirty)
                        Rectangle {
                            width: Tokens.sp-10 * 2;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: root.dirty
                                ? (apply-btn-touch.has-hover ? Tokens.bg-hover : Tokens.accent)
                                : Tokens.bg-3;
                            border-radius: Tokens.r-md;
                            opacity: root.dirty ? 1.0 : 0.5;

                            Text {
                                text: "Apply";
                                color: root.dirty ? Tokens.accent-fg : Tokens.fg-3;
                                font-size: Tokens.fs-13;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            apply-btn-touch := TouchArea {
                                enabled: root.dirty;
                                clicked => { root.apply-requested(); }
                            }
                        }

                        // OK (solid)
                        Rectangle {
                            width: Tokens.sp-10 * 2;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: ok-btn-touch.has-hover ? Tokens.bg-hover : Tokens.status-seeding;
                            border-radius: Tokens.r-md;

                            Text {
                                text: "OK";
                                color: Tokens.accent-fg;
                                font-size: Tokens.fs-13;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            ok-btn-touch := TouchArea {
                                clicked => { root.ok-requested(); }
                            }
                        }
                    }
                }
            }

        }

        // ── Shared PrefSelect popup overlay ──
        // Lives at scrim level (sibling of centered card) so absolute
        // coordinates from PrefSelect map directly to window space.
        if root.popup-visible: Rectangle {
            width: parent.width;
            height: parent.height;

            popup-dismiss := TouchArea {
                clicked => { root.popup-visible = false; }
            }

            Rectangle {
                x: root.popup-x;
                y: root.popup-y;
                width: root.popup-width;
                height: popup-option-layout.preferred-height + Tokens.sp-4;
                background: Tokens.bg-1;
                border-color: Tokens.border-1;
                border-width: Tokens.border-width-thin;
                border-radius: Tokens.r-md;
                drop-shadow-color: Tokens.shadow-lg.color;
                drop-shadow-blur: Tokens.shadow-lg.blur;
                drop-shadow-offset-y: Tokens.shadow-lg.offset-y;

                TouchArea { }

                popup-option-layout := VerticalLayout {
                    padding: Tokens.sp-2;
                    spacing: Tokens.sp-1;

                    for option in root.popup-items: Rectangle {
                        height: 30px;
                        background: popup-opt-touch.has-hover
                            ? Tokens.bg-hover
                            : (option == root.popup-current ? Tokens.bg-selected : Tokens.bg-1);
                        border-radius: Tokens.r-sm;

                        Text {
                            text: option;
                            color: Tokens.fg-0;
                            font-size: Tokens.fs-13;
                            vertical-alignment: center;
                            x: Tokens.sp-4;
                        }

                        popup-opt-touch := TouchArea {
                            clicked => {
                                root.popup-visible = false;
                                root.select-popup-value(root.popup-id, option);
                            }
                        }
                    }
                }
            }
        }
    }

    function select-popup-value(id: string, value: string) {
        root.dirty = true;
        if id == "skin"         { root.pref-skin = value; }
        if id == "theme"        { root.pref-theme = value; }
        if id == "density"      { root.pref-density = value; }
        if id == "radius"       { root.pref-radius = value; }
        if id == "dblclick"     { root.pref-double-click-action = value; }
        if id == "proxy-type"   { root.pref-proxy-type = value; }
        if id == "encryption"   { root.pref-encryption-mode = value; }
        if id == "ratio-action" { root.pref-max-ratio-action = value; }
        if id == "ddns"         { root.pref-ddns-service = value; }
    }
}
