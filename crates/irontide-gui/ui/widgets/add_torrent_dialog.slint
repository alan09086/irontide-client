// Add Torrent File Dialog — modal overlay for selecting and adding a .torrent file.
// Custom widgets only (no std-widgets) for consistent hit regions.

import { Tokens } from "../tokens.slint";

export component AddTorrentDialog {
    in property <bool> show;
    in property <string> default-dir;
    in property <string> torrent-name: "";
    in property <string> torrent-size: "";
    in property <int> torrent-file-count: 0;
    in property <string> selected-file-path: "";
    callback add-confirmed(string, string);  // (path, download_dir)
    callback cancel();
    callback browse-torrent-file();
    callback browse-download-dir();

    if root.show: Rectangle {
        // Full-window backdrop
        background: Tokens.bg-0.with-alpha(80%);

        // Consume clicks on backdrop to dismiss
        backdrop-touch := TouchArea {
            clicked => { root.cancel(); }
        }

        // Dialog box centered
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: Tokens.sp-10 * 12;
            height: dialog-layout.preferred-height + Tokens.sp-9;
            background: Tokens.bg-2;
            border-color: Tokens.border-1;
            border-width: Tokens.border-width-thin;
            border-radius: Tokens.r-lg;

            // Block backdrop click from reaching through dialog
            TouchArea { }

            dialog-layout := VerticalLayout {
                padding: Tokens.sp-6;
                spacing: Tokens.sp-5;

                // Title
                Text {
                    text: "Add Torrent File";
                    color: Tokens.fg-0;
                    font-size: Tokens.fs-16;
                    font-weight: 700;
                }

                // File selection: display path + Browse button
                VerticalLayout {
                    spacing: Tokens.sp-2;
                    Text { text: "File:"; color: Tokens.fg-0; font-size: Tokens.fs-13; }
                    HorizontalLayout {
                        spacing: Tokens.sp-4;
                        Rectangle {
                            horizontal-stretch: 1;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: Tokens.bg-inset;
                            border-color: Tokens.border-2;
                            border-width: Tokens.border-width-thin;
                            border-radius: Tokens.r-md;

                            // Display-only text for selected file path
                            Text {
                                x: Tokens.sp-4;
                                color: root.selected-file-path == "" ? Tokens.fg-3 : Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                vertical-alignment: center;
                                overflow: elide;
                                text: root.selected-file-path == "" ? "(no file selected)" : root.selected-file-path;
                                width: parent.width - Tokens.sp-6;
                            }
                        }
                        Rectangle {
                            width: Tokens.sp-10 * 2;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: browse-file-touch.has-hover ? Tokens.bg-hover : Tokens.accent;
                            border-radius: Tokens.r-md;

                            Text {
                                text: "Browse...";
                                color: Tokens.accent-fg;
                                font-size: Tokens.fs-13;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            browse-file-touch := TouchArea {
                                accessible-role: button;
                                accessible-label: "Browse torrent file";
                                clicked => { root.browse-torrent-file(); }
                            }
                        }
                    }
                }

                // Torrent info panel (visible only after file is selected)
                if root.torrent-name != "": Rectangle {
                    background: Tokens.bg-0;
                    border-color: Tokens.border-1;
                    border-width: Tokens.border-width-thin;
                    border-radius: Tokens.r-md;
                    height: info-layout.preferred-height + Tokens.sp-6;

                    info-layout := VerticalLayout {
                        padding: Tokens.sp-4;
                        spacing: Tokens.sp-2;

                        Text {
                            text: "Torrent Info";
                            color: Tokens.fg-0;
                            font-size: Tokens.fs-12;
                            font-weight: 700;
                        }

                        HorizontalLayout {
                            spacing: Tokens.sp-6;
                            Text {
                                text: "Name: " + root.torrent-name;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }

                        HorizontalLayout {
                            spacing: Tokens.sp-6;
                            Text {
                                text: "Size: " + root.torrent-size;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                            }
                            Text {
                                text: "Files: " + root.torrent-file-count;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-12;
                            }
                        }
                    }
                }

                // Download directory label + input + Browse
                VerticalLayout {
                    spacing: Tokens.sp-2;
                    Text { text: "Download to:"; color: Tokens.fg-0; font-size: Tokens.fs-13; }
                    HorizontalLayout {
                        spacing: Tokens.sp-4;
                        Rectangle {
                            horizontal-stretch: 1;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: Tokens.bg-inset;
                            border-color: Tokens.border-2;
                            border-width: Tokens.border-width-thin;
                            border-radius: Tokens.r-md;

                            dir-input := TextInput {
                                accessible-label: "Download directory";
                                x: Tokens.sp-4;
                                y: 0;
                                width: parent.width - Tokens.sp-6;
                                height: parent.height;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                text: root.default-dir;
                            }
                        }
                        Rectangle {
                            width: Tokens.sp-10 * 2;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: browse-dir-touch.has-hover ? Tokens.bg-hover : Tokens.accent;
                            border-radius: Tokens.r-md;

                            Text {
                                text: "Browse...";
                                color: Tokens.accent-fg;
                                font-size: Tokens.fs-13;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            browse-dir-touch := TouchArea {
                                accessible-role: button;
                                accessible-label: "Browse download directory";
                                clicked => { root.browse-download-dir(); }
                            }
                        }
                    }
                }

                // Buttons row
                HorizontalLayout {
                    alignment: end;
                    spacing: Tokens.sp-4;

                    // Cancel
                    Rectangle {
                        width: Tokens.sp-10 * 2;
                        height: Tokens.chrome-h - Tokens.sp-2;
                        background: cancel-touch.has-hover ? Tokens.bg-hover : Tokens.accent;
                        border-radius: Tokens.r-md;

                        Text {
                            text: "Cancel";
                            color: Tokens.accent-fg;
                            font-size: Tokens.fs-13;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cancel-touch := TouchArea {
                            accessible-role: button;
                            accessible-label: "Cancel";
                            clicked => { root.cancel(); }
                        }
                    }

                    // Add (disabled when no file selected)
                    Rectangle {
                        width: Tokens.sp-10 * 2;
                        height: Tokens.chrome-h - Tokens.sp-2;
                        background: root.torrent-name == "" ? Tokens.accent : (add-touch.has-hover ? Tokens.bg-hover : Tokens.status-seeding);
                        border-radius: Tokens.r-md;
                        opacity: root.torrent-name == "" ? 0.5 : 1.0;

                        Text {
                            text: "Add";
                            color: Tokens.accent-fg;
                            font-size: Tokens.fs-13;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        add-touch := TouchArea {
                            accessible-role: button;
                            accessible-label: "Add torrent";
                            enabled: root.torrent-name != "";
                            clicked => { root.add-confirmed(root.selected-file-path, dir-input.text); }
                        }
                    }
                }
            }
        }
    }
}
