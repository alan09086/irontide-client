// Status bar at the bottom of the main window.

import { Tokens } from "../tokens.slint";

export component StatusBar {
    in property <string> down-rate: "\u{2014}";
    in property <string> up-rate: "\u{2014}";
    in property <int> total-torrents: 0;
    in property <int> dht-nodes: 0;
    in property <int> listen-port: 0;

    height: Tokens.chrome-h - Tokens.sp-5;

    Rectangle {
        background: Tokens.bg-2;
        border-width: 0;

        HorizontalLayout {
            padding-left: Tokens.sp-4;
            padding-right: Tokens.sp-4;
            spacing: Tokens.sp-6;

            // Left: rates
            Text {
                text: "\u{2193} " + root.down-rate;
                color: Tokens.fg-0;
                font-size: Tokens.fs-12;
                vertical-alignment: center;
            }
            Text {
                text: "\u{2191} " + root.up-rate;
                color: Tokens.fg-0;
                font-size: Tokens.fs-12;
                vertical-alignment: center;
            }

            // Spacer
            Rectangle { horizontal-stretch: 1; }

            // Right: counts
            Text {
                text: root.total-torrents + " torrents";
                color: Tokens.fg-3;
                font-size: Tokens.fs-12;
                vertical-alignment: center;
            }
            Text {
                text: "DHT: " + root.dht-nodes;
                color: Tokens.fg-3;
                font-size: Tokens.fs-12;
                vertical-alignment: center;
            }
            Text {
                text: "Port: " + root.listen-port;
                color: Tokens.fg-3;
                font-size: Tokens.fs-12;
                vertical-alignment: center;
            }
        }
    }
}
