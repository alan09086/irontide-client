// IronTide right-click context menu overlay.
// Custom overlay pattern (not PopupWindow) to avoid Slint native positioning issues.

import { Tokens } from "../tokens.slint";

export component ContextMenu {
    in property <bool> show;
    in property <length> menu-x;
    in property <length> menu-y;
    // Enable flags for smart context menu
    in property <bool> can-pause: true;
    in property <bool> can-resume: true;
    in property <bool> can-seed-only: true;
    in property <bool> can-resume-download: true;
    in property <bool> can-recheck: true;
    callback context-action(int);  // action index
    callback dismiss();

    if root.show: Rectangle {
        // Transparent full-window overlay to catch clicks outside
        background: transparent;

        dismiss-touch := TouchArea {
            pointer-event(e) => {
                if (e.kind == PointerEventKind.up) {
                    root.dismiss();
                }
            }
        }

        // Menu box at cursor position
        Rectangle {
            x: root.menu-x;
            y: root.menu-y;
            width: Tokens.sp-10 * 5;
            height: menu-layout.preferred-height + Tokens.sp-4;
            background: Tokens.bg-1;
            border-color: Tokens.border-1;
            border-width: Tokens.border-width-thin;
            border-radius: Tokens.r-md;

            // Block dismiss click from passing through
            TouchArea { }

            menu-layout := VerticalLayout {
                padding: Tokens.sp-2;
                spacing: Tokens.sp-1;

                // Item 0: Pause
                Rectangle {
                    height: Tokens.row-h;
                    background: root.can-pause ? (pause-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1) : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Pause";
                        color: root.can-pause ? Tokens.fg-0 : Tokens.fg-3;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        x: Tokens.sp-4;
                    }

                    pause-touch := TouchArea {
                        enabled: root.can-pause;
                        clicked => { root.context-action(0); }
                    }
                }

                // Item 1: Resume
                Rectangle {
                    height: Tokens.row-h;
                    background: root.can-resume ? (resume-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1) : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Resume";
                        color: root.can-resume ? Tokens.fg-0 : Tokens.fg-3;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        x: Tokens.sp-4;
                    }

                    resume-touch := TouchArea {
                        enabled: root.can-resume;
                        clicked => { root.context-action(1); }
                    }
                }

                // Item 2: Seed Only
                Rectangle {
                    height: Tokens.row-h;
                    background: root.can-seed-only ? (seed-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1) : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Seed Only";
                        color: root.can-seed-only ? Tokens.fg-0 : Tokens.fg-3;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        x: Tokens.sp-4;
                    }

                    seed-touch := TouchArea {
                        enabled: root.can-seed-only;
                        clicked => { root.context-action(2); }
                    }
                }

                // Item 3: Resume Download
                Rectangle {
                    height: Tokens.row-h;
                    background: root.can-resume-download ? (resume-dl-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1) : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Resume Download";
                        color: root.can-resume-download ? Tokens.fg-0 : Tokens.fg-3;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        x: Tokens.sp-4;
                    }

                    resume-dl-touch := TouchArea {
                        enabled: root.can-resume-download;
                        clicked => { root.context-action(3); }
                    }
                }

                // Separator
                Rectangle {
                    height: Tokens.border-width-thin;
                    background: Tokens.border-1;
                }

                // Item 4: Remove (always enabled)
                Rectangle {
                    height: Tokens.row-h;
                    background: remove-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Remove";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        x: Tokens.sp-4;
                    }

                    remove-touch := TouchArea {
                        clicked => { root.context-action(4); }
                    }
                }

                // Item 5: Remove + Delete Files (always enabled)
                Rectangle {
                    height: Tokens.row-h;
                    background: remove-del-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Remove + Delete Files";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        x: Tokens.sp-4;
                    }

                    remove-del-touch := TouchArea {
                        clicked => { root.context-action(5); }
                    }
                }

                // Separator
                Rectangle {
                    height: Tokens.border-width-thin;
                    background: Tokens.border-1;
                }

                // Item 6: Recheck
                Rectangle {
                    height: Tokens.row-h;
                    background: root.can-recheck ? (recheck-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1) : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Recheck";
                        color: root.can-recheck ? Tokens.fg-0 : Tokens.fg-3;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        x: Tokens.sp-4;
                    }

                    recheck-touch := TouchArea {
                        enabled: root.can-recheck;
                        clicked => { root.context-action(6); }
                    }
                }

                // Item 7: Force Reannounce (always enabled)
                Rectangle {
                    height: Tokens.row-h;
                    background: reannounce-touch.has-hover ? Tokens.bg-hover : Tokens.bg-1;
                    border-radius: Tokens.r-sm;

                    Text {
                        text: "Force Reannounce";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;
                        x: Tokens.sp-4;
                    }

                    reannounce-touch := TouchArea {
                        clicked => { root.context-action(7); }
                    }
                }
            }
        }
    }
}
