// Add Magnet Dialog — modal overlay for entering a magnet URI.
// Custom widgets only (no std-widgets) for consistent hit regions.

import { Tokens } from "../tokens.slint";

export component AddMagnetDialog {
    in property <bool> show;
    in property <string> default-dir;
    callback add-confirmed(string, string);
    callback cancel();
    callback browse-download-dir();

    if root.show: Rectangle {
        // Full-window backdrop
        background: Tokens.bg-0.with-alpha(80%);

        // Consume clicks on backdrop to dismiss
        backdrop-touch := TouchArea {
            clicked => { root.cancel(); }
        }

        // Dialog box centered
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: Tokens.sp-10 * 12;
            height: dialog-layout.preferred-height + Tokens.sp-9;
            background: Tokens.bg-2;
            border-color: Tokens.border-1;
            border-width: Tokens.border-width-thin;
            border-radius: Tokens.r-lg;

            // Block backdrop click from reaching through dialog
            TouchArea { }

            dialog-layout := VerticalLayout {
                padding: Tokens.sp-6;
                spacing: Tokens.sp-5;

                // Title
                Text {
                    text: "Add Magnet Link";
                    color: Tokens.fg-0;
                    font-size: Tokens.fs-16;
                    font-weight: 700;
                }

                // URI label + input
                VerticalLayout {
                    spacing: Tokens.sp-2;
                    Text { text: "Magnet URI:"; color: Tokens.fg-0; font-size: Tokens.fs-13; }
                    Rectangle {
                        height: Tokens.chrome-h - Tokens.sp-2;
                        background: Tokens.bg-inset;
                        border-color: Tokens.border-2;
                        border-width: Tokens.border-width-thin;
                        border-radius: Tokens.r-md;

                        uri-input := TextInput {
                            accessible-label: "Magnet URI";
                            x: Tokens.sp-4;
                            y: 0;
                            width: parent.width - Tokens.sp-6;
                            height: parent.height;
                            color: Tokens.fg-0;
                            font-size: Tokens.fs-13;
                        }
                        // Placeholder text when empty
                        if uri-input.text == "": Text {
                            x: Tokens.sp-4;
                            color: Tokens.fg-3;
                            font-size: Tokens.fs-13;
                            text: "magnet:?xt=urn:btih:...";
                            vertical-alignment: center;
                        }
                    }
                }

                // Download directory label + input + Browse
                VerticalLayout {
                    spacing: Tokens.sp-2;
                    Text { text: "Download to:"; color: Tokens.fg-0; font-size: Tokens.fs-13; }
                    HorizontalLayout {
                        spacing: Tokens.sp-4;
                        Rectangle {
                            horizontal-stretch: 1;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: Tokens.bg-inset;
                            border-color: Tokens.border-2;
                            border-width: Tokens.border-width-thin;
                            border-radius: Tokens.r-md;

                            dir-input := TextInput {
                                accessible-label: "Download directory";
                                x: Tokens.sp-4;
                                y: 0;
                                width: parent.width - Tokens.sp-6;
                                height: parent.height;
                                color: Tokens.fg-0;
                                font-size: Tokens.fs-13;
                                text: root.default-dir;
                            }
                        }
                        Rectangle {
                            width: Tokens.sp-10 * 2;
                            height: Tokens.chrome-h - Tokens.sp-2;
                            background: browse-touch.has-hover ? Tokens.bg-hover : Tokens.accent;
                            border-radius: Tokens.r-md;

                            Text {
                                text: "Browse...";
                                color: Tokens.accent-fg;
                                font-size: Tokens.fs-13;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            browse-touch := TouchArea {
                                accessible-role: button;
                                accessible-label: "Browse download directory";
                                clicked => { root.browse-download-dir(); }
                            }
                        }
                    }
                }

                // Buttons row
                HorizontalLayout {
                    alignment: end;
                    spacing: Tokens.sp-4;

                    // Cancel
                    Rectangle {
                        width: Tokens.sp-10 * 2;
                        height: Tokens.chrome-h - Tokens.sp-2;
                        background: cancel-touch.has-hover ? Tokens.bg-hover : Tokens.accent;
                        border-radius: Tokens.r-md;

                        Text {
                            text: "Cancel";
                            color: Tokens.accent-fg;
                            font-size: Tokens.fs-13;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cancel-touch := TouchArea {
                            accessible-role: button;
                            accessible-label: "Cancel";
                            clicked => { root.cancel(); }
                        }
                    }

                    // Add (disabled when URI empty)
                    Rectangle {
                        width: Tokens.sp-10 * 2;
                        height: Tokens.chrome-h - Tokens.sp-2;
                        background: uri-input.text == "" ? Tokens.accent : (add-touch.has-hover ? Tokens.bg-hover : Tokens.status-seeding);
                        border-radius: Tokens.r-md;
                        opacity: uri-input.text == "" ? 0.5 : 1.0;

                        Text {
                            text: "Add";
                            color: Tokens.accent-fg;
                            font-size: Tokens.fs-13;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        add-touch := TouchArea {
                            accessible-role: button;
                            accessible-label: "Add magnet";
                            enabled: uri-input.text != "";
                            clicked => { root.add-confirmed(uri-input.text, dir-input.text); }
                        }
                    }
                }
            }
        }
    }
}
