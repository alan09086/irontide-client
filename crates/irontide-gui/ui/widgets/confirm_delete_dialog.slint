// Delete confirmation dialog — modal overlay shown before removing torrents.
// Custom widgets only (no std-widgets) for consistent hit regions.

import { Tokens } from "../tokens.slint";

export component ConfirmDeleteDialog {
    in property <bool> show;
    in property <int> count: 0;
    in property <bool> delete-files: false;
    callback delete-confirmed(/* delete_files */ bool);
    callback cancel();

    // Internal checkbox state. Initialised from `delete-files` via binding;
    // the binding is broken on first user toggle, then re-established when
    // the dialog reopens with a fresh `delete-files` value.
    in-out property <bool> check-active: root.delete-files;

    if root.show: Rectangle {
        // Full-window backdrop at 80% opacity
        background: Tokens.bg-0.with-alpha(80%);

        backdrop-touch := TouchArea {
            clicked => { root.cancel(); }
        }

        // Dialog box centered
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: Tokens.sp-10 * 10;
            height: dialog-layout.preferred-height + Tokens.sp-9;
            background: Tokens.bg-2;
            border-color: Tokens.border-1;
            border-width: Tokens.border-width-thin;
            border-radius: Tokens.r-lg;

            // Block backdrop click from reaching through dialog
            TouchArea { }

            dialog-layout := VerticalLayout {
                padding: Tokens.sp-6;
                spacing: Tokens.sp-5;

                // Title
                Text {
                    text: "Remove Torrent(s)";
                    color: Tokens.fg-0;
                    font-size: Tokens.fs-16;
                    font-weight: 700;
                }

                // Message
                Text {
                    text: "Remove " + root.count + " selected torrent(s)?";
                    color: Tokens.fg-0;
                    font-size: Tokens.fs-13;
                }

                // Custom checkbox: "Also delete files on disk"
                HorizontalLayout {
                    spacing: Tokens.sp-4;
                    alignment: start;

                    // Checkbox box
                    Rectangle {
                        width: Tokens.sp-7 - Tokens.sp-1;
                        height: Tokens.sp-7 - Tokens.sp-1;
                        border-width: Tokens.border-width-thin;
                        border-color: Tokens.border-2;
                        border-radius: Tokens.r-sm;
                        background: Tokens.bg-inset;

                        if root.check-active: Text {
                            text: "\u{2713}";
                            color: Tokens.status-seeding;
                            font-size: Tokens.fs-14;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        check-state := TouchArea {
                            accessible-role: checkbox;
                            accessible-label: "Also delete files on disk";
                            clicked => { root.check-active = !root.check-active; }
                        }
                    }

                    // Checkbox label (also clickable)
                    Text {
                        text: "Also delete files on disk";
                        color: Tokens.fg-0;
                        font-size: Tokens.fs-13;
                        vertical-alignment: center;

                        label-touch := TouchArea {
                            clicked => { root.check-active = !root.check-active; }
                        }
                    }
                }

                // Buttons row
                HorizontalLayout {
                    alignment: end;
                    spacing: Tokens.sp-4;

                    // Cancel
                    Rectangle {
                        width: Tokens.sp-10 * 2;
                        height: Tokens.chrome-h - Tokens.sp-2;
                        background: cancel-touch.has-hover ? Tokens.bg-hover : Tokens.accent;
                        border-radius: Tokens.r-md;

                        Text {
                            text: "Cancel";
                            color: Tokens.accent-fg;
                            font-size: Tokens.fs-13;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        cancel-touch := TouchArea {
                            accessible-role: button;
                            accessible-label: "Cancel";
                            clicked => { root.cancel(); }
                        }
                    }

                    // Remove (danger colour)
                    Rectangle {
                        width: Tokens.sp-10 * 2;
                        height: Tokens.chrome-h - Tokens.sp-2;
                        background: remove-touch.has-hover ? Tokens.status-error.darker(0.15) : Tokens.status-error;
                        border-radius: Tokens.r-md;

                        Text {
                            text: "Remove";
                            color: Tokens.fg-0;
                            font-size: Tokens.fs-13;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        remove-touch := TouchArea {
                            accessible-role: button;
                            accessible-label: "Remove";
                            clicked => { root.delete-confirmed(root.check-active); }
                        }
                    }
                }
            }
        }
    }
}
