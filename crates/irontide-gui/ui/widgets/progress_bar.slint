// Custom progress bar widget for torrent list rows.

import { Tokens } from "../tokens.slint";

export component TorrentProgressBar {
    in property <float> progress: 0.0;
    in property <color> fill-color: Tokens.status-seeding;
    in property <string> progress-text: "";

    height: Tokens.sp-6 - Tokens.sp-1;

    // Track
    Rectangle {
        background: Tokens.bg-2;
        border-radius: Tokens.r-sm;

        // Fill
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width * clamp(root.progress, 0.0, 1.0);
            height: parent.height;
            background: root.fill-color;
            border-radius: Tokens.r-sm;
        }

        // Percentage text overlay
        Text {
            text: root.progress-text;
            color: Tokens.fg-0;
            font-size: Tokens.fs-10;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
