// IronTide design tokens — skeleton populated by Lane A, values by Lane B.
//
// Shape:
// - `struct Shadow` bundles color/blur/offset-y for drop-shadow-* binding.
// - `export global Tokens { in-out property ... }` — all props mutated by
//   `SkinSettings::apply` in Rust.
//
// Placeholder defaults are Tide-dark baked values so first paint is correct
// (but gated on `skin-applied` — see main.slint).

export struct Shadow {
    color: color,
    blur: length,
    offset-y: length,
}

export global Tokens {
    // ── Colours (active palette — Tide-dark defaults, codegen-aligned) ─
    // Each default matches the value in scripts/tokens.hex.json for the
    // `tide-dark` skin so the first paint is correct pre-apply. Rust's
    // SkinSettings::apply() overwrites these on startup.
    in-out property <color> bg-0:           #0d1115;  // spec: oklch(0.175 0.010 250)
    in-out property <color> bg-1:           #13181c;  // spec: oklch(0.205 0.011 250)
    in-out property <color> bg-2:           #181c21;  // spec: oklch(0.225 0.012 250)
    in-out property <color> bg-3:           #1c2127;  // spec: oklch(0.245 0.013 250)
    in-out property <color> bg-hover:       #21272d;  // spec: oklch(0.27  0.014 250)
    in-out property <color> bg-selected:    #193841;  // spec: oklch(0.32  0.04  220)
    in-out property <color> bg-inset:       #080c0f;  // spec: oklch(0.15  0.010 250)
    in-out property <color> fg-0:           #eff2f4;  // spec: oklch(0.96  0.004 240)
    in-out property <color> fg-1:           #c1c5c8;  // spec: oklch(0.82  0.006 240)
    in-out property <color> fg-2:           #8b9094;  // spec: oklch(0.65  0.008 240)
    in-out property <color> fg-3:           #5e6468;  // spec: oklch(0.50  0.010 240)
    in-out property <color> border-1:       #292e34;  // spec: oklch(0.30  0.012 250)
    in-out property <color> border-2:       #383e44;  // spec: oklch(0.36  0.014 250)
    in-out property <color> divider:        #25292f;  // spec: oklch(0.28  0.012 250)
    in-out property <color> accent:         #1db8ce;  // spec: oklch(0.72  0.12  210)
    in-out property <color> accent-hover:   #22cde5;  // spec: oklch(0.78  0.13  210)
    in-out property <color> accent-fg:      #040c13;  // spec: oklch(0.15  0.02  240)
    in-out property <color> accent-bg-soft: #03343c;  // spec: oklch(0.30  0.05  210)

    // ── Status colours (shared across skins/themes) ─────────────────
    in-out property <color> status-downloading: #00b0d5;  // spec: oklch(0.70 0.14 220)
    in-out property <color> status-seeding:     #53be70;  // spec: oklch(0.72 0.15 150)
    in-out property <color> status-paused:      #86909b;  // spec: oklch(0.65 0.02 250)
    in-out property <color> status-checking:    #a497ea;  // spec: oklch(0.72 0.12 290)
    in-out property <color> status-metadata:    #b98dff;  // placeholder (no CSS entry)
    in-out property <color> status-queued:      #c69e58;  // spec: oklch(0.72 0.10  80)
    in-out property <color> status-error:       #e85854;  // spec: oklch(0.65 0.18  25)
    in-out property <color> status-stalled:     #6e8398;  // spec: oklch(0.60 0.04 250)

    // ── Spacing (sp-1 … sp-10) ──────────────────────────────────────
    in-out property <length> sp-1:  2px;
    in-out property <length> sp-2:  4px;
    in-out property <length> sp-3:  6px;
    in-out property <length> sp-4:  8px;
    in-out property <length> sp-5: 12px;
    in-out property <length> sp-6: 16px;
    in-out property <length> sp-7: 20px;
    in-out property <length> sp-8: 24px;
    in-out property <length> sp-9: 32px;
    in-out property <length> sp-10: 40px;

    // ── Radii ───────────────────────────────────────────────────────
    in-out property <length> r-sm: 3px;
    in-out property <length> r-md: 6px;
    in-out property <length> r-lg: 10px;
    in-out property <length> r-xl: 14px;

    // ── Density (row-h / row-px / chrome-h / sidebar-w / filters-w) ─
    in-out property <length> row-h:     32px;
    in-out property <length> row-px:     8px;
    in-out property <length> chrome-h:  40px;
    in-out property <length> sidebar-w: 240px;
    in-out property <length> filters-w: 200px;

    // ── Font sizes (fs-10 … fs-32) ─────────────────────────────────
    in-out property <length> fs-10: 10px;
    in-out property <length> fs-11: 11px;
    in-out property <length> fs-12: 12px;
    in-out property <length> fs-13: 13px;
    in-out property <length> fs-14: 14px;
    in-out property <length> fs-16: 16px;
    in-out property <length> fs-18: 18px;
    in-out property <length> fs-24: 24px;
    in-out property <length> fs-32: 32px;

    // ── Border widths ──────────────────────────────────────────────
    in-out property <length> border-width-thin:   1px;
    in-out property <length> border-width-medium: 2px;
    in-out property <length> border-width-thick:  4px;

    // ── Shadows (struct-shaped) ───────────────────────────────────
    in-out property <Shadow> shadow-sm: { color: #0000004d, blur: 4px,  offset-y: 1px };
    in-out property <Shadow> shadow-md: { color: #0000006b, blur: 8px,  offset-y: 2px };
    in-out property <Shadow> shadow-lg: { color: #00000099, blur: 16px, offset-y: 4px };

    // ── Motion durations ───────────────────────────────────────────
    in-out property <duration> dur-fast: 80ms;
    in-out property <duration> dur:      150ms;
    in-out property <duration> dur-slow: 300ms;

    // ── Identity strings (for test assertions + branching) ─────────
    in-out property <string> active-skin:  "tide";
    in-out property <string> active-theme: "dark";

    // ── Torrent-list column defaults ───────────────────────────────
    // These are not design tokens in the strict sense — they're layout
    // defaults that Rust's ColumnConfig::from_gui_config may override
    // at startup. Holding them here keeps literal px values out of the
    // widget files (enforced by scripts/ci-tokens-drift.sh upstream).
    in-out property <length> col-default-name:     100px;
    in-out property <length> col-default-progress: 120px;
    in-out property <length> col-default-state:     90px;
    in-out property <length> col-default-rate:      80px;
    in-out property <length> col-default-count:     50px;
    in-out property <length> col-default-eta:       70px;
    in-out property <length> col-default-ratio:     60px;
    in-out property <length> col-width-threshold:  780px;
    in-out property <length> col-width-non-name-total: 680px;

    // ── Window-size defaults ───────────────────────────────────────
    // Slint's Window min/preferred sizes must be `length`, and reactive
    // Token arithmetic in these positions is awkward, so we define them
    // as concrete tokens here.
    in-out property <length> win-min-width:        700px;
    in-out property <length> win-min-height:       400px;
    in-out property <length> win-preferred-width:  900px;
    in-out property <length> win-preferred-height: 600px;
}

